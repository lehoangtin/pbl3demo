@model IEnumerable<StudyShare.Models.Document>
@{
    ViewData["Title"] = "StudyShare - Mạng Lưới Tri Thức";
    var categories = ViewBag.Categories as List<StudyShare.Models.Category>;
    int? currentCatId = ViewBag.CurrentCategory as int?;
}

<div id="neural-intro">
    <canvas id="network-canvas"></canvas>
    
    <div id="white-flash"></div>

    <div class="intro-ui" id="ui-content">
        <h1 class="cyber-title">STUDYSHARE</h1>
        <p class="cyber-subtitle">Mạng lưới chia sẻ tri thức đang chờ đồng bộ...</p>
        <button class="btn-cyber" onclick="activateNetwork()">
            [ KÍCH HOẠT KẾT NỐI ]
        </button>
    </div>
</div>

<div class="container mt-4" id="main-library-content" style="opacity: 0; transition: opacity 2s ease;">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Thư viện tài liệu học tập</h1>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-filter-left"></i> Lọc theo danh mục</h5>
            <div class="list-group shadow-sm">
                <a asp-action="Index" class="list-group-item list-group-item-action @(currentCatId == null ? "active" : "")">
                   Tất cả tài liệu
                </a>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-searchTerm="@ViewBag.SearchTerm"
                           class="list-group-item list-group-item-action @(currentCatId == cat.Id ? "active" : "")">
                            @cat.Name
                        </a>
                    }
                }
            </div>
        </div>

        <div class="col-md-9">
            <div class="row mb-4">
                <div class="col-12">
                    <form asp-action="Index" method="get" class="d-flex shadow-sm bg-white p-2 rounded-3">
                        <input type="hidden" name="categoryId" value="@currentCatId" />
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                               class="form-control border-0 me-2" placeholder="Tìm trong danh mục này..." />
                        <button type="submit" class="btn btn-primary px-4 rounded-pill">Tìm kiếm</button>
                    </form>
                </div>
            </div>

            <div class="row">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body">
                                    <h6 class="fw-bold">@item.Title</h6>
                                    <p class="text-muted small mb-2"><i class="bi bi-person-circle"></i> @(item.User?.FullName ?? "Thành viên StudyShare")</p>
                                    <span class="badge bg-info text-dark">@item.Category?.Name</span>
                                </div>
                                <div class="card-footer bg-white border-0">
                                    <a asp-action="ViewDocument" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-100">Xem</a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5"><p class="text-muted">Không tìm thấy tài liệu nào.</p></div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    body.no-scroll { overflow: hidden; background: #020204; }

    #neural-intro {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 99999; background: #020204;
        transition: opacity 1s ease-in-out;
    }

    #network-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }

    .intro-ui {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        z-index: 5; pointer-events: none; transition: opacity 0.5s;
    }

    .cyber-title {
        font-size: 5rem; font-weight: 900; letter-spacing: 15px; color: #fff;
        text-shadow: 0 0 20px #00e5ff, 0 0 40px #00e5ff;
        margin-bottom: 10px; font-family: monospace;
    }

    .cyber-subtitle { 
        color: #e8f0fe; /* Đổi sang màu trắng ngả xanh sáng hơn để dễ đọc */
        font-size: 1.5rem; /* Tăng kích thước chữ */
        font-weight: 900; /* Làm chữ cực kỳ đậm */
        letter-spacing: 4px; /* Tăng khoảng cách giữa các chữ để nhìn thoáng và ngầu hơn */
        font-family: monospace; 
        margin-bottom: 50px; 
        /* Thêm hiệu ứng phát sáng (Glow) quanh viền chữ để tách biệt hoàn toàn khỏi nền */
        text-shadow: 0 0 10px rgba(0, 229, 255, 0.8), 0 0 20px rgba(0, 229, 255, 0.4); 
    }
    .btn-cyber {
        pointer-events: auto; padding: 15px 40px; font-size: 1.2rem; font-weight: bold;
        background: rgba(0, 229, 255, 0.05); color: #00e5ff;
        border: 2px solid #00e5ff; border-radius: 4px; cursor: pointer;
        transition: all 0.3s ease; font-family: monospace; letter-spacing: 2px;
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
    }
    .btn-cyber:hover {
        background: #00e5ff; color: #000; box-shadow: 0 0 30px #00e5ff, inset 0 0 10px #fff;
    }

    #white-flash {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: white; z-index: 10; opacity: 0; pointer-events: none;
        transition: opacity 1s;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const hasSeenIntro = sessionStorage.getItem("hasSeenStudyShareNetwork");

        if (!hasSeenIntro) {
            document.body.classList.add("no-scroll");
            initCanvas(); // Chạy đồ họa hạt
        } else {
            document.getElementById("neural-intro").remove();
            document.getElementById("main-library-content").style.opacity = "1";
        }
    });

    let canvas, ctx, particlesArray, mouse, isExploding = false;

    function initCanvas() {
        canvas = document.getElementById("network-canvas");
        ctx = canvas.getContext("2d");
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        particlesArray = [];
        mouse = { x: null, y: null, radius: 150 };

        window.addEventListener('mousemove', function(event) {
            mouse.x = event.x;
            mouse.y = event.y;
        });

        class Particle {
            constructor(x, y, vx, vy, size) {
                this.x = x; this.y = y;
                this.vx = vx; this.vy = vy;
                this.size = size;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2, false);
                ctx.fillStyle = '#00e5ff';
                ctx.fill();
            }
            update() {
                if(isExploding) {
                    // Gia tốc khi nổ
                    this.x += this.vx * 15;
                    this.y += this.vy * 15;
                } else {
                    // Chuyển động bình thường
                    if(this.x > canvas.width || this.x < 0) this.vx = -this.vx;
                    if(this.y > canvas.height || this.y < 0) this.vy = -this.vy;
                    
                    // Tránh né chuột
                    let dx = mouse.x - this.x;
                    let dy = mouse.y - this.y;
                    let distance = Math.sqrt(dx*dx + dy*dy);
                    if(distance < mouse.radius) {
                        this.x -= dx/20;
                        this.y -= dy/20;
                    }
                    this.x += this.vx;
                    this.y += this.vy;
                }
                this.draw();
            }
        }

        // Tạo 150 hạt ban đầu
        for(let i = 0; i < 150; i++) {
            let size = Math.random() * 2 + 1;
            let x = Math.random() * innerWidth;
            let y = Math.random() * innerHeight;
            let vx = (Math.random() - 0.5) * 1.5;
            let vy = (Math.random() - 0.5) * 1.5;
            particlesArray.push(new Particle(x, y, vx, vy, size));
        }

        animate();
    }

    function animate() {
        requestAnimationFrame(animate);
        ctx.clearRect(0, 0, innerWidth, innerHeight);

        for(let i = 0; i < particlesArray.length; i++) {
            particlesArray[i].update();
        }
        connect();
    }

    // Vẽ đường nối các hạt (Neural Network)
    function connect() {
        if(isExploding) return; // Khi nổ thì tắt nối dây cho ngầu
        for(let a = 0; a < particlesArray.length; a++) {
            for(let b = a; b < particlesArray.length; b++) {
                let dx = particlesArray[a].x - particlesArray[b].x;
                let dy = particlesArray[a].y - particlesArray[b].y;
                let distance = dx * dx + dy * dy;

                if(distance < 15000) {
                    let opacity = 1 - (distance/15000);
                    ctx.strokeStyle = 'rgba(0, 229, 255, ' + opacity + ')';
                    ctx.lineWidth = 1;
                    ctx.beginPath();
                    ctx.moveTo(particlesArray[a].x, particlesArray[a].y);
                    ctx.lineTo(particlesArray[b].x, particlesArray[b].y);
                    ctx.stroke();
                }
            }
        }
    }

    // Kích hoạt hiệu ứng Nổ (Warp Speed)
    function activateNetwork() {
        document.getElementById('ui-content').style.opacity = '0'; // Ẩn giao diện
        
        // Điều hướng các hạt bay ra từ tâm màn hình
        let cx = canvas.width / 2;
        let cy = canvas.height / 2;
        particlesArray.forEach(p => {
            p.vx = (p.x - cx) * 0.02;
            p.vy = (p.y - cy) * 0.02;
        });

        isExploding = true; // Bật cờ nổ

        // Chớp sáng sau 0.8 giây
        setTimeout(() => {
            document.getElementById('white-flash').style.opacity = '1';
        }, 800);

        // Vô trang chủ sau 1.5 giây
        setTimeout(() => {
            document.getElementById('neural-intro').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('neural-intro').remove();
                document.body.classList.remove("no-scroll");
                document.getElementById("main-library-content").style.opacity = "1";
                sessionStorage.setItem("hasSeenStudyShareNetwork", "true");
            }, 1000);
        }, 1500);
    }
</script>