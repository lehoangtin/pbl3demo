@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body style="padding-top: 80px;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book-half fs-3 me-2 text-warning"></i> StudyShare
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-collection me-1"></i> Thư viện
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="User" asp-controller="Chat" asp-action="Index">
                                <i class="bi bi-robot me-1"></i> Trợ lí AI
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="User" asp-controller="Question" asp-action="Index">
                                <i class="bi bi-chat-dots me-1"></i> Thảo luận
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="User" asp-controller="Ranking" asp-action="Index">
                                <i class="bi bi-trophy me-1"></i> Bảng vàng
                            </a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-warning fw-bold" href="#" data-bs-toggle="dropdown">
                                        <i class="bi bi-speedometer2"></i> Quản trị
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow mt-2" style="border-radius: 12px;">
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">Người dùng</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Document" asp-action="Index">Tài liệu</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Question" asp-action="Index">Q&A</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="User" asp-controller="Document" asp-action="Create">
                                        <i class="bi bi-cloud-arrow-up me-1"></i> Tải lên
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="min-height: 80vh;">
        <main role="main" class="pb-5 pt-4">
            
            @* Hệ thống thông báo hiện đại *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i>
                    <strong>Thành công!</strong> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5 align-middle"></i>
                    <strong>Lỗi!</strong> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @* Body Render *@
            @RenderBody()
            
        </main>
    </div>

    <footer class="bg-white text-muted py-4 mt-auto border-top shadow-sm">
        <div class="container text-center">
            <span class="fw-bold text-primary">StudyShare</span> &copy; 2026 - Xây dựng với <i class="bi bi-heart-fill text-danger"></i>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/scripts.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>