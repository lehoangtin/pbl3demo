@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <div class="aesthetic-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-custom fixed-top container mt-3">
            <div class="container-fluid px-3">
                <a class="navbar-brand d-flex align-items-center fs-4" asp-area="" asp-controller="Home" asp-action="Index" style="color: #6366f1; font-weight: 800;">
                    <i class="bi bi-journal-code me-2 fs-3"></i> StudyShare
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-grid-fill me-1"></i> Thư viện
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Chat" asp-action="Index">
                                <i class="bi bi-magic me-1 text-warning"></i> Trợ lí AI
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Question" asp-action="Index">
                                <i class="bi bi-chat-heart-fill me-1 text-danger"></i> Thảo luận
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Ranking" asp-action="Index">
                                <i class="bi bi-award-fill me-1 text-success"></i> Bảng vàng
                            </a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" style="color: #475569;">
                                        <i class="bi bi-shield-lock-fill me-1"></i> Quản trị
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow-sm mt-2">
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">Người dùng</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Document" asp-action="Index">Tài liệu</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Question" asp-action="Index">Q&A</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item ms-lg-2">
                                    <a class="btn btn-primary btn-sm rounded-pill px-4 py-2 mt-lg-1 d-flex align-items-center" asp-area="User" asp-controller="Document" asp-action="Create">
                                        <i class="bi bi-cloud-arrow-up-fill me-2"></i> Tải lên
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="min-height: 80vh;">
        <main role="main" class="pb-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3 border-0" role="alert" style="background: rgba(209, 231, 221, 0.9); border-radius: 16px;">
                    <i class="bi bi-check2-circle me-2 fs-5 text-success align-middle"></i>
                    <strong class="text-success">Tuyệt vời!</strong> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3 border-0" role="alert" style="background: rgba(254, 226, 226, 0.9); border-radius: 16px;">
                    <i class="bi bi-exclamation-octagon me-2 fs-5 text-danger align-middle"></i>
                    <strong class="text-danger">Lỗi rồi!</strong> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="mt-4 pt-2">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="mt-auto py-4 w-100" style="background: transparent;">
        <div class="container text-center" style="color: #64748b; font-weight: 600;">
            StudyShare &copy; 2026 - Thắp sáng đam mê học tập <i class="bi bi-stars text-warning"></i>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/scripts.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>