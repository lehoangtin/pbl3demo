@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-white d-flex align-items-center fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="~/avatar/1.png" alt="Avatar" class="rounded-circle me-2 border border-2 border-white" style="width: 35px; height: 35px; object-fit: cover;">
            <span>@User.Identity?.Name</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2" aria-labelledby="userDropdown" style="border-radius: 12px; min-width: 200px;">
            <li>
                <a class="dropdown-item py-2" asp-area="User" asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person me-2 text-primary"></i>Hồ sơ của tôi
                </a>
            </li>
            <li>
                <a class="dropdown-item py-2" asp-area="User" asp-controller="User" asp-action="SavedDocuments">
                    <i class="bi bi-bookmark-heart me-2 text-danger"></i>Tài liệu đã lưu
                </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item text-danger py-2 fw-bold">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item d-flex align-items-center me-2">
        <a class="btn btn-outline-light px-4 rounded-pill btn-sm" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
    </li>
    <li class="nav-item d-flex align-items-center">
        <a class="btn btn-warning px-4 rounded-pill btn-sm fw-bold" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký</a>
    </li>
}
</ul>