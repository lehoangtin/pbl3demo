@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    // Vẫn giữ đoạn code nhận diện Avatar của bạn
    var userAvatar = currentUser?.Avatar ?? "1.png"; 
}

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" style="color: #334155;">
            <img src="~/avatar/@userAvatar" alt="Avatar" class="rounded-circle me-2" style="width: 42px; height: 42px; object-fit: cover; border: 3px solid #e0e7ff; padding: 2px;">
            <span class="fw-bold">@User.Identity?.Name</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-3 border-0 shadow-lg" aria-labelledby="userDropdown">
            <li>
                <a class="dropdown-item py-2 my-1" asp-area="User" asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person-hearts me-2 text-primary fs-5 align-middle"></i> Hồ sơ của tôi
                </a>
            </li>
            <li>
                <a class="dropdown-item py-2 my-1" asp-area="User" asp-controller="User" asp-action="SavedDocuments">
                    <i class="bi bi-bookmark-star-fill me-2 text-warning fs-5 align-middle"></i> Tài liệu đã lưu
                </a>
            </li>
            <li><hr class="dropdown-divider mx-3"></li>
            <li>
                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item text-danger py-2 my-1 fw-bold">
                        <i class="bi bi-box-arrow-right me-2 fs-5 align-middle"></i> Đăng xuất
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item me-3">
        <a class="nav-link fw-bold" asp-area="" asp-controller="Account" asp-action="Login" style="color: #6366f1;">Đăng nhập</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary px-4 py-2 rounded-pill shadow-sm" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
    </li>
}
</ul>