@model StudyShare.Models.AppUser
@using StudyShare.Models
@{
    ViewData["Title"] = "Hồ sơ: " + Model.FullName;

    // Ép kiểu an toàn từ ViewBag
    var docs = ViewBag.RecentDocuments as List<Document> ?? new List<Document>();
    var questions = ViewBag.RecentQuestions as List<Question> ?? new List<Question>();
    var reports = ViewBag.UserReports as List<Report> ?? new List<Report>();
}

<div class="container-fluid px-4 mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="bg-primary p-5 text-white">
                <div class="d-flex align-items-center">
                    <img src="@(Model.Avatar ?? "/images/default-avatar.png")" 
                         class="rounded-circle border border-4 border-white shadow" 
                         style="width: 120px; height: 120px; object-fit: cover;">
                    <div class="ms-4">
                        <h2 class="fw-bold mb-1">@Model.FullName</h2>
                        <p class="mb-2 opacity-75">@Model.Email</p>
                        <div class="d-flex gap-2">
                            <span class="badge bg-white text-primary rounded-pill px-3">@ViewBag.Roles</span>
                            @if (Model.IsBanned) {
                                <span class="badge bg-danger rounded-pill px-3">🚫 Đã khóa</span>
                            } else {
                                <span class="badge bg-light text-dark rounded-pill px-3">✅ Hoạt động</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-3">Hành động quản trị</h5>
                <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post" class="d-grid gap-2">
                    @if (Model.IsBanned) {
                        <button type="submit" class="btn btn-success rounded-pill">Mở khóa tài khoản</button>
                    } else {
                        <button type="submit" class="btn btn-outline-danger rounded-pill" onclick="return confirm('Khóa người dùng này?')">Khóa vì vi phạm</button>
                    }
                </form>
            </div>

            <div class="card shadow-sm border-0 rounded-4 p-4">
                <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-flag"></i> Báo cáo (@reports.Count)</h5>
                @foreach (var r in reports) {
                    <div class="small border-bottom mb-2 pb-2">
                        <strong>@r.Reason</strong>
                        <div class="text-muted">Bởi: @(r.Reporter?.FullName ?? "Ẩn danh")</div>
                    </div>
                }
                @if (!reports.Any()) { <p class="text-muted small">Không có báo cáo nào.</p> }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-3 text-primary">Tài liệu gần đây</h5>
                <table class="table table-sm">
                    <tbody>
                        @foreach (var d in docs) {
                            <tr>
                                <td>@d.Title</td>
                                <td class="text-end text-muted">@d.UploadDate.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card shadow-sm border-0 rounded-4 p-4">
                <h5 class="fw-bold mb-3 text-success">Câu hỏi gần đây</h5>
                @foreach (var q in questions) 
    {
        <div class="border-bottom mb-2 pb-2">
            <p class="mb-0 small">@q.Content</p>
            <small class="text-muted">Ngày: @q.CreatedAt.ToString("dd/MM/yyyy")</small>
        </div>
    }
    
    @if (!questions.Any()) {
        <p class="text-muted small">Người dùng này chưa đặt câu hỏi nào.</p>
    }

            </div>
        </div>
    </div>
</div>