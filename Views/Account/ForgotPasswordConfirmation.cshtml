@{
    ViewData["Title"] = "Xác nhận gửi email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-lg border-0 p-5 rounded-4">
                <div class="mb-4">
                    <i class="bi bi-envelope-check text-success" style="font-size: 4rem;"></i>
                </div>
                <h2 class="fw-bold text-primary mb-3">Kiểm tra Gmail của bạn</h2>
                
                @* Hiển thị thông báo tùy biến từ Controller *@
                <p class="lead text-muted">
                    @(ViewBag.Message ?? "Chúng tôi đã gửi một liên kết đến email của bạn. Vui lòng kiểm tra hộp thư (và cả thư rác) để tiếp tục.")
                </p>

                <div class="mt-4">
                    <a href="/" class="btn btn-outline-primary px-4 rounded-pill">Quay lại trang chủ</a>
                    <a asp-action="Login" class="btn btn-primary px-4 rounded-pill ms-2">Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">