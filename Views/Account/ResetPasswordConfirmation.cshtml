@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm p-4 border-0 rounded-4">
                <div class="card-body">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                    <h2 class="fw-bold mt-3">Thành công!</h2>
                    <p class="text-muted">Mật khẩu của bạn đã được đặt lại thành công.</p>
                    <hr />
                    <a asp-action="Login" asp-controller="Account" class="btn btn-primary rounded-pill px-4">
                        Đăng nhập ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>