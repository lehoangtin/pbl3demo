@model StudyShare.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Đặt lại mật khẩu"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold text-primary">Tạo mật khẩu mới</h3>
                
                <form asp-action="ResetPassword" method="post">
                    @* 🔥 Hiển thị tất cả lỗi từ Identity (Ví dụ: thiếu ký tự đặc biệt, thiếu số...) *@
                    <div asp-validation-summary="All" class="alert alert-danger small p-3 mb-4" 
                         style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
                    </div>

                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input asp-for="NewPassword" class="form-control rounded-pill" type="password" 
                               placeholder="Tối thiểu 8 ký tự, có chữ hoa, số, ký tự đặc biệt" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-pill" type="password" 
                               placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm">
                        Lưu mật khẩu mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* 🔥 Quan trọng: Phải có dòng này để báo lỗi ngay trên trình duyệt *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}