@model StudyShare.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Đặt lại mật khẩu"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold text-primary">Tạo mật khẩu mới</h3>
                
                <form asp-action="ResetPassword" method="post">
                  @* Sửa thành All để thấy mọi lỗi từ Server gửi về *@
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <input type="hidden" asp-for="Token" />
    <input type="hidden" asp-for="Email" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email của bạn</label>
                        <input class="form-control rounded-pill bg-light" value="@Model.Email" disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input asp-for="NewPassword" class="form-control rounded-pill" type="password" 
                               placeholder="Tối thiểu 8 ký tự, chữ hoa, số, ký tự đặc biệt" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-pill" type="password" 
                               placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm">
                        Lưu mật khẩu mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>