@model StudyShare.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold text-primary">Đăng nhập</h3>
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input asp-for="Password" class="form-control" type="password" />
                    </div>
                    <div class="mb-3 text-end">
                        <a asp-action="ForgotPassword" class="small text-decoration-none">Quên mật khẩu?</a>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Đăng nhập</button>
                </form>
            </div>
        </div>
    </div>
</div>