@model StudyShare.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Quên mật khẩu"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold mb-2">Bạn quên mật khẩu?</h4>
                <p class="text-muted small mb-4">Nhập email đăng ký của bạn. Chúng tôi sẽ gửi một liên kết an toàn để bạn đặt lại mật khẩu mới.</p>
                
                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-start"></div>
                    
                    <div class="mb-4 text-start">
                        <label class="form-label fw-bold">Email khôi phục</label>
                        <input asp-for="Email" class="form-control rounded-pill" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 py-2 fw-bold rounded-pill shadow-sm">
                        Gửi liên kết khôi phục
                    </button>
                </form>

                <div class="mt-4">
                    <a asp-action="Login" class="text-decoration-none small text-muted">
                        <i class="bi bi-arrow-left"></i> Quay lại trang Đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}