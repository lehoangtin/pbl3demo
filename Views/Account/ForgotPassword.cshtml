@model StudyShare.ViewModels.ForgotPasswordViewModel
<div class="row justify-content-center mt-5">
    <div class="col-md-4 text-center">
        <h4 class="fw-bold">Bạn quên mật khẩu?</h4>
        <p class="text-muted">Nhập email chúng tôi sẽ gửi link khôi phục</p>
        <form asp-action="ForgotPassword" method="post" class="mt-4">
            <input asp-for="Email" class="form-control mb-3" placeholder="Nhập email của bạn" />
            <button type="submit" class="btn btn-warning w-100">Gửi mail khôi phục</button>
        </form>
    </div>
</div>