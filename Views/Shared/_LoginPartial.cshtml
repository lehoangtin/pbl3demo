@using Microsoft.AspNetCore.Identity
@* Thêm dòng using này để trình biên dịch hiểu AppUser là gì *@
@using StudyShare.Models 
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav ms-auto"> @* ms-auto để đẩy menu sang bên phải *@

    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        <li class="nav-item d-flex align-items-center me-3">
            @* Sửa Points thành Point cho khớp với AppUser Model *@
            <span class="badge rounded-pill bg-warning text-dark me-2">
                <i class="bi bi-coin"></i> @(user?.Points ?? 0)đ
            </span>
            <span class="navbar-text text-light">
                👋 Chào, <strong>@(User.Identity?.Name ?? "User")</strong>
            </span>
        </li>

        <li class="nav-item">
            @* Sửa lại asp-controller thành User và asp-action thành Profile *@
            <a class="nav-link" asp-area="User" asp-controller="User" asp-action="Profile">
                <i class="bi bi-person"></i> Profile
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link border-0" style="cursor:pointer">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
        </li>

        <li class="nav-item">
            <a class="nav-link btn btn-primary text-white ms-lg-2" asp-controller="Account" asp-action="Register">Register</a>
        </li>
    }
</ul>
