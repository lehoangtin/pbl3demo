@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        /* 1. NỀN GRADIENT CHẤM BI XỊN SÒ */
        body {
            background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 50%, #fffde7 100%) !important;
            background-image: radial-gradient(#cfd8dc 1px, transparent 1px) !important;
            background-size: 25px 25px !important;
            background-attachment: fixed !important;
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* 2. STYLE CHO TIÊU ĐỀ "XỊN" (Dùng class .hero-title cho các chữ quan trọng) */
        .hero-title {
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: -1.5px;
            background: linear-gradient(to right, #0d47a1, #1976d2, #42a5f5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        /* 3. NAVBAR MỜ KÍNH (Glassmorphism) */
        .navbar {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            background-color: rgba(33, 37, 41, 0.9) !important;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        /* 4. TÙY CHỈNH THẺ CARD NỔI BẬT */
        .card {
            border: none !important;
            border-radius: 20px !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05) !important;
            background-color: rgba(255, 255, 255, 0.95) !important;
            transition: transform 0.3s ease;
        }

        .container { background-color: transparent !important; }
        footer { border-top: none !important; background: transparent !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-info" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book-half me-2"></i>StudyShare
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Thư viện chung</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-area="User" asp-controller="Chat" asp-action="Index">Trợ lí AI</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-area="User" asp-controller="Question" asp-action="Index">Thảo luận</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-area="User" asp-controller="Ranking" asp-action="Index">Bảng vàng</a></li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-warning" href="#" data-bs-toggle="dropdown">
                                        <i class="bi bi-speedometer2 me-1"></i> Quản trị
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-dark shadow-lg">
                                        <li><a class="dropdown-item fw-bold text-info" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-house-gear me-2"></i>Dashboard</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index"><i class="bi bi-people me-2"></i> Người dùng</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Document" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i> Tài liệu</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Question" asp-action="Index"><i class="bi bi-question-circle me-2"></i> Q&A</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Category" asp-action="Index"><i class="bi bi-tags me-2"></i> Danh mục</a></li>
                                        <li><a class="dropdown-item text-danger" asp-area="Admin" asp-controller="User" asp-action="PendingReports"><i class="bi bi-flag-fill me-2"></i> Báo cáo vi phạm</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link text-white" asp-area="User" asp-controller="Document" asp-action="Create">Tải lên</a></li>
                                <li class="nav-item"><a class="nav-link text-white" asp-area="User" asp-controller="Document" asp-action="Index">Tài liệu của tôi</a></li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @* THÔNG BÁO TEMP DATA *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-pill px-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-pill px-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-auto py-4">
        <div class="container text-center">
            <small>&copy; 2026 - <span class="text-primary fw-bold">StudyShare</span> Community</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* --- LOGIC MODAL KHÓA TÀI KHOẢN --- *@
    @if (User.Identity.IsAuthenticated)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null && (currentUser.WarningCount >= 3 || currentUser.IsBanned))
        {
            <div class="modal fade" id="violationModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                        <div class="modal-header bg-danger text-white border-0" style="border-radius: 20px 20px 0 0;">
                            <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-octagon-fill me-2"></i>TÀI KHOẢN BỊ KHÓA</h5>
                        </div>
                        <div class="modal-body text-center py-5">
                            <div class="mb-4">
                                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 5rem; opacity: 0.8;"></i>
                            </div>
                            <h4 class="fw-bold text-dark">Bạn đã vi phạm @currentUser.WarningCount lần!</h4>
                            <p class="text-muted px-4 mt-3">
                                Tài khoản của bạn đã bị khóa vĩnh viễn do tích lũy đủ số lần vi phạm tiêu chuẩn cộng đồng của <b>StudyShare</b>.
                            </p>
                            <hr class="mx-5 my-4">
                            <small class="text-secondary">Liên hệ hỗ trợ: <span class="fw-bold">admin@studyshare.com</span></small>
                        </div>
                        <div class="modal-footer border-0 justify-content-center pb-5">
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger rounded-pill px-5 py-2 fw-bold shadow-lg">
                                    ĐĂNG XUẤT NGAY
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    var myModal = new bootstrap.Modal(document.getElementById('violationModal'));
                    myModal.show();
                });
            </script>
        }
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>