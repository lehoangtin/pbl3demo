<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>StudyShare</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" asp-controller="Document" asp-action="Index">StudyShare</a>

        <div>
            <a class="btn btn-outline-light" asp-controller="Document" asp-action="Create">Upload</a>
            <a class="btn btn-outline-light" asp-controller="Question" asp-action="Index">Q&A</a>
            <a class="btn btn-outline-light" asp-area="Identity" asp-page="/Account/Login">Login</a>
            <a class="btn btn-outline-light" asp-controller="Question" asp-action="Index">Q&A</a>
        </div>
    </div>
</nav>

<div class="container mt-4">
    @RenderBody()
</div>
<partial name="_LoginPartial" />
</body>
</html>