<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>StudyShare</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" asp-controller="Document" asp-action="Index">StudyShare</a>

        <div class="navbar-nav ms-auto">
    @if (User.Identity.IsAuthenticated)
    {
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-outline-light me-2" asp-area="Admin" asp-controller="Document" asp-action="Index">Quản lý Tài liệu</a>
            <a class="btn btn-outline-light me-2" asp-area="Admin" asp-controller="Question" asp-action="Index">Quản lý Q&A</a>
            <a class="btn btn-outline-light me-2" asp-area="Admin" asp-controller="User" asp-action="Index">Quản lý User</a>
            
        }
        else
        {
            <a class="btn btn-outline-light me-2" asp-area="User" asp-controller="Document" asp-action="Create">Upload</a>
            <a class="btn btn-outline-light me-2" asp-area="User" asp-controller="Question" asp-action="Index">Q&A</a>
            <a class="btn btn-outline-light me-2" asp-area="User" asp-controller="User" asp-action="Profile">Hồ sơ</a>
        }
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-danger">Logout</button>
        </form>
    }
    else
    {
        <a class="btn btn-outline-light me-2" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
        <a class="btn btn-light" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
    }
</div>
    </div>
</nav>

<div class="container mt-4">
    @RenderBody()
</div>
<partial name="_LoginPartial" />
</body>
</html>