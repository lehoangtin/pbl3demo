﻿@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">StudyShare</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Thư viện chung</a>
                        </li>

                        @* --- DI CHUYỂN MỤC THẢO LUẬN RA NGOÀI ĐÂY --- *@
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold" asp-area="User" asp-controller="Question" asp-action="Index">Thảo luận</a>
                        </li>
                        @* ------------------------------------------- *@

                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-warning" href="#" id="adminMenu" data-bs-toggle="dropdown">
                                        <i class="bi bi-speedometer2 me-1"></i> Quản trị
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-dark">
                                        <li>
                                            <a class="dropdown-item fw-bold text-info" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                                <i class="bi bi-house-gear me-2"></i>Trang Dashboard
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">Người dùng</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Document" asp-action="Index">Tài liệu</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Question" asp-action="Index">Quản lý Q&A</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Category" asp-action="Index">Quản lý Danh mục</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="ReportedUsers">Quản lý vi phạm</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" asp-area="User" asp-controller="Document" asp-action="Create">Tải lên</a></li>
                                <li class="nav-item"><a class="nav-link" asp-area="User" asp-controller="Document" asp-action="Index">Tài liệu của tôi</a></li>
                                @* Mục Thảo luận cũ đã được xóa ở đây vì đã đưa ra ngoài *@
                            }
                        }
                    </ul>
                    
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody() 
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - StudyShare
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
