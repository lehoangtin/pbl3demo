@model StudyShare.Models.Document
@using System.Security.Claims @* Thêm dòng này để lấy ID người dùng *@
@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Thư viện</a></li>
            <li class="breadcrumb-item active">@Model.Category?.Name</li>
        </ol>
    </nav>
<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h3 class="fw-bold text-primary">@Model.Title</h3>
                    <hr />
                    <p><strong>Mô tả:</strong> @Model.Description</p>
                    <p><strong>Người đăng:</strong> @(Model.User?.FullName ?? "Thành viên StudyShare")</p>
                    <p><strong>Ngày đăng:</strong> @Model.UploadDate.ToString("dd/MM/yyyy")</p>
                    <p><strong>Lượt xem:</strong> <span class="badge bg-secondary">@Model.Views</span></p>
                    
                    <div class="d-grid gap-2 mt-4">
                        @* 🔥 TẢI XUỐNG - GỌI ACTION TRỪ ĐIỂM *@
                        <a asp-area="User" asp-controller="Document" asp-action="Download" asp-route-id="@Model.Id" 
                           class="btn btn-success" onclick="return confirm('Bạn sẽ bị trừ 10 điểm để tải. Tiếp tục?')">
                            <i class="bi bi-download"></i> Tải xuống (10đ)
                        </a>

                        @* 🔥 LƯU / BỎ LƯU TÀI LIỆU *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            if (ViewBag.IsSaved == true)
                            {
                                <form asp-area="User" asp-controller="User" asp-action="UnsaveDocument" method="post">
                                    <input type="hidden" name="docId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-bookmark-check-fill"></i> Đã lưu</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="User" asp-controller="User" asp-action="SaveDocument" method="post">
                                    <input type="hidden" name="docId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-bookmark-plus"></i> Lưu tài liệu</button>
                                </form>
                            }
                        }

                        @* XOÁ TÀI LIỆU (CỦA CHỦ SỞ HỮU) *@
                        @if (User.Identity.IsAuthenticated && Model.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                        {
                            <form asp-area="User" asp-controller="User" asp-action="DeleteDocument" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Xóa vĩnh viễn tài liệu này?')">
                                <button type="submit" class="btn btn-danger w-100"><i class="bi bi-trash"></i> Xóa tài liệu của tôi</button>
                            </form>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại thư viện</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="height: 800px;">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-eye me-2"></i> Xem trước tài liệu</span>
                    <small>@Model.FileName</small>
                </div>
                <div class="card-body p-0">
                    @if (Model.FileType.Contains("pdf"))
                    {
                        <iframe src="@Model.FilePath#toolbar=0" width="100%" height="100%" style="border: none;"></iframe>
                    }
                    else if (Model.FileType.Contains("image"))
                    {
                        <div class="text-center p-3 h-100 d-flex align-items-center">
                            <img src="@Model.FilePath" class="img-fluid rounded mx-auto d-block" alt="Preview" />
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-file-earmark-zip text-warning" style="font-size: 5rem;"></i>
                            <h4 class="mt-3">Định dạng file này không hỗ trợ xem trực tuyến</h4>
                            <p class="text-muted">Vui lòng nhấn nút "Tải xuống" ở bên trái để xem nội dung.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>