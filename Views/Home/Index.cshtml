@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{
    ViewData["Title"] = "Thư viện chung";
    // 🔥 Đã sửa thành CategoryResponse để khớp với Architecture
    var categories = ViewBag.Categories as IEnumerable<StudyShare.DTOs.Responses.CategoryResponse>;
    int? currentCatId = ViewBag.CurrentCategory as int?;
}

<div class="container mt-4 mb-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary"><i class="bi bi-book-half me-2"></i>Thư viện tài liệu</h1>
        <p class="text-muted fs-5">Khám phá và chia sẻ kiến thức cùng cộng đồng</p>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-filter-left"></i> Lọc theo danh mục</h5>
            <div class="list-group shadow-sm rounded-4 overflow-hidden border-0">
                <a asp-action="Index" asp-route-searchTerm="@ViewBag.SearchTerm"
                   class="list-group-item list-group-item-action py-3 border-0 border-bottom @(currentCatId == null ? "active fw-bold" : "")">
                   <i class="bi bi-grid-fill me-2"></i> Tất cả tài liệu
                </a>

                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <a asp-action="Index" 
                           asp-route-categoryId="@cat.Id" 
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           class="list-group-item list-group-item-action py-3 border-0 border-bottom @(currentCatId == cat.Id ? "active fw-bold" : "")">
                            <i class="bi bi-folder2-open me-2"></i> @cat.Name
                        </a>
                    }
                }
            </div>
        </div>

        <div class="col-md-9">
            <div class="row mb-4">
                <div class="col-12">
                    <form asp-action="Index" method="get" class="d-flex shadow-sm bg-white p-2 rounded-pill border">
                        <input type="hidden" name="categoryId" value="@currentCatId" />
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                               class="form-control border-0 bg-transparent ms-2 shadow-none" placeholder="Nhập tên tài liệu cần tìm..." />
                        <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </form>
                </div>
            </div>

            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                                <div class="card-body p-4">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle mb-2 px-2 py-1 rounded-3">@item.CategoryName</span>
                                    <h5 class="card-title fw-bold text-dark text-truncate" title="@item.Title">@item.Title</h5>
                                    <p class="text-muted small mb-0 mt-2">
                                        <i class="bi bi-person-circle me-1"></i> Đăng bởi: <strong>@item.AuthorName</strong>
                                    </p>
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-calendar3 me-1"></i> @item.UploadDate.ToString("dd/MM/yyyy")
                                    </p>
                                </div>
                                <div class="card-footer bg-light border-top-0 p-3">
                                    <a asp-action="ViewDocument" asp-route-id="@item.Id" class="btn btn-info w-100 rounded-pill text-white fw-bold shadow-sm">
                                        <i class="bi bi-eye me-1"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 bg-light rounded-4 border border-dashed">
                        <i class="bi bi-search text-secondary opacity-50" style="font-size: 4rem;"></i>
                        <h4 class="mt-3 text-dark">Không tìm thấy tài liệu</h4>
                        <p class="text-muted">Không có tài liệu nào khớp với từ khóa hoặc danh mục bạn chọn.</p>
                        <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 mt-2">Xóa bộ lọc</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>