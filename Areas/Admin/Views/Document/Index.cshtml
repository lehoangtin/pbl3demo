@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{
    ViewData["Title"] = "Quản lý tài liệu";
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row">
        <div class="col-md-3 col-lg-2 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9 col-lg-10">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-bottom">
                    <div class="row align-items-center g-3">
                        <div class="col-md-5">
                            <h4 class="m-0 fw-bold text-primary"><i class="bi bi-file-earmark-text me-2"></i>Kho tài liệu</h4>
                        </div>
                        <div class="col-md-7">
                            <form asp-action="Index" method="get">
                                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                                    <span class="input-group-text bg-light border-0 ps-3">
                                        <i class="bi bi-search text-muted"></i>
                                    </span>
                                    <input type="text" name="searchString" class="form-control border-0 bg-light py-2" 
                                           placeholder="Tìm theo tiêu đề, người đăng..." value="@ViewData["CurrentFilter"]" />
                                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                                    {
                                        <a asp-action="Index" class="btn btn-light border-0 d-flex align-items-center px-3" title="Xóa tìm kiếm">
                                            <i class="bi bi-x-lg text-muted"></i>
                                        </a>
                                    }
                                    <button type="submit" class="btn btn-primary px-4 fw-bold">Tìm</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-semibold" style="width: 40%">TÀI LIỆU</th>
                                    <th class="text-muted fw-semibold" style="width: 20%">NGƯỜI ĐĂNG</th>
                                    <th class="text-muted fw-semibold" style="width: 15%">TRẠNG THÁI</th>
                                    <th class="text-end pe-4 text-muted fw-semibold" style="width: 25%">THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-primary-subtle rounded p-2 me-3 text-center d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                                        <i class="bi bi-file-earmark-font fs-4 text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold mb-1 text-dark text-truncate" style="max-width: 250px;" title="@item.Title">@item.Title</h6>
                                                        <small class="text-muted">@item.CategoryName • @item.FileType</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="fw-medium text-dark">@item.AuthorName</span>
                                            </td>
                                            <td>
                                                @if (item.IsApproved)
                                                {
                                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> Đã duyệt</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning px-3 py-2"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group shadow-sm rounded-3 overflow-hidden border">
                                                    @if (!item.IsApproved)
                                                    {
                                                        <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-white border-0 py-2 px-3 text-info" title="Kiểm duyệt">
                                                            <i class="bi bi-shield-check"></i> Duyệt
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-white border-0 py-2 px-3 text-primary" title="Xem chi tiết">
                                                            <i class="bi bi-eye-fill"></i>
                                                        </a>
                                                    }
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài liệu này?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-white border-0 py-2 px-3 text-danger border-start" title="Xóa tài liệu">
                                                            <i class="bi bi-trash-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted border-0">
                                            <i class="bi bi-folder2-open display-4 opacity-50 d-block mb-3"></i>
                                            <p class="mb-0">Không tìm thấy tài liệu nào.</p>
                                            <a asp-action="Index" class="btn btn-link btn-sm mt-1">Xóa bộ lọc</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background-color: #fff; }
    .btn-white:hover { background-color: #f8f9fa; }
</style>