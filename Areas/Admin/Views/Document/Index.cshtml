@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{
    ViewData["Title"] = "Quản lý tài liệu";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 d-flex justify-content-between align-items-center border-bottom">
                    <h4 class="m-0 fw-bold text-primary"><i class="bi bi-file-earmark-text me-2"></i>Quản lý kho tài liệu</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 40%">Tài liệu</th>
                                    <th style="width: 20%">Người đăng</th>
                                    <th style="width: 15%">Trạng thái</th>
                                    <th class="text-end pe-4" style="width: 25%">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-light rounded p-2 me-3 text-center" style="width: 45px; height: 45px;">
                                                        <i class="bi bi-file-earmark-font fs-4 text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold mb-1 text-dark text-truncate" style="max-width: 250px;" title="@item.Title">@item.Title</h6>
                                                        <small class="text-muted">@item.CategoryName • @item.FileType</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="fw-medium text-dark">@item.AuthorName</span>
                                            </td>
                                            <td>
                                                @if (item.IsApproved)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success px-2 py-1"><i class="bi bi-check-circle me-1"></i> Đã duyệt</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-warning border border-warning px-2 py-1"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group">
                                                    @if (!item.IsApproved)
                                                    {
                                                        <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white rounded-pill px-3 me-2 shadow-sm fw-bold">
                                                            <i class="bi bi-search me-1"></i> Kiểm duyệt
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-2 shadow-sm">
                                                            <i class="bi bi-eye me-1"></i> Xem
                                                        </a>
                                                    }
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài liệu này?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted border-0">
                                            <i class="bi bi-folder2-open display-4 opacity-50 d-block mb-3"></i>
                                            Kho tài liệu hiện đang trống.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>