@model StudyShare.ViewModels.QuestionViewModel
@{
    ViewData["Title"] = "Chi tiết thảo luận";
}

<div class="container-fluid py-4" style="background-color: #f8f9fc; min-height: 100vh;">
    <div class="row g-4">
        <div class="col-xl-3 col-lg-4 d-none d-lg-block">
            <div class="sticky-top" style="top: 20px;">
                @await Html.PartialAsync("_AdminSidebarPartial")
            </div>
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                <a asp-action="Index" class="btn btn-white border rounded-pill px-4 fw-medium shadow-sm hover-lift">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
                </a>
                <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa hoàn toàn câu hỏi và mọi bình luận bên trong?');">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold">
                        <i class="bi bi-trash3-fill me-2"></i> Xóa toàn bộ Topic
                    </button>
                </form>
            </div>

            @if (TempData["Success"] != null) {
                <div class="alert alert-success border-0 shadow-sm rounded-4 px-4 py-3 mb-4 animate__animated animate__fadeIn">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-primary p-4 text-white d-flex align-items-center" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);">
                    <div class="bg-white rounded-circle p-2 me-3 shadow-sm" style="width: 55px; height: 55px;">
                        <img src="/images/default-avatar.png" class="w-100" alt="avatar">
                    </div>
                    <div>
                        <h5 class="m-0 fw-bold">@Model.AuthorName</h5>
                        <small class="opacity-75"><i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <span class="ms-auto badge bg-white text-primary rounded-pill px-3 py-2 fw-bold shadow-sm">@Model.CategoryName</span>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="bg-light p-4 rounded-4 border-start border-4 border-primary mb-2">
                        <h4 class="text-dark m-0" style="line-height: 1.6; font-weight: 500;">@Model.Content</h4>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-5 border-top border-info border-4">
                <div class="card-header bg-white p-4 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold m-0 text-dark"><i class="bi bi-chat-dots-fill text-info me-2"></i>Tất cả bình luận (@Model.AnswerCount)</h5>
                </div>

                @if (Model.Answers != null && Model.Answers.Any()) {
                    <div class="list-group list-group-flush">
                        @foreach (var ans in Model.Answers) {
                            <div class="list-group-item p-4 border-bottom border-light hover-bg">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-start w-100">
                                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; flex-shrink: 0;">
                                            <i class="bi bi-chat-text"></i>
                                        </div>
                                        <div class="w-100 pe-3">
                                            <div class="d-flex justify-content-between mb-1">
                                                <h6 class="fw-bold text-dark m-0">@ans.AuthorName</h6>
                                                <small class="text-muted">@ans.CreatedAt.ToString("HH:mm dd/MM/yyyy")</small>
                                            </div>
                                            <p class="text-secondary mb-0 fs-6">@ans.Content</p>
                                        </div>
                                    </div>
                                    
                                    <form asp-action="DeleteAnswer" method="post" onsubmit="return confirm('Xóa bình luận này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ans.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 border-0 shadow-sm" title="Xóa vi phạm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                } else {
                    <div class="text-center py-5 text-muted bg-light rounded-bottom-4">
                        <i class="bi bi-chat-left-dots display-4 d-block mb-3 opacity-25"></i>
                        <p class="mb-0">Chưa có bình luận nào cho thảo luận này.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .hover-bg:hover { background-color: #fcfcfc; }
    .btn-white { background: white; color: #495057; }
    .btn-white:hover { background: #f8f9fa; }
    .hover-lift:hover { transform: translateY(-2px); }
    .hover-lift { transition: all 0.2s; }
</style>