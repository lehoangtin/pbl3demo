@model StudyShare.ViewModels.QuestionViewModel
@{
    ViewData["Title"] = "Chi tiết thảo luận";
}

<div class="container-fluid py-4" style="background-color: #f8f9fc; min-height: 100vh;">
    <div class="row g-4">
        <div class="col-xl-2 col-lg-3">
            <div class="sticky-top" style="top: 20px;">
                @await Html.PartialAsync("_AdminSidebarPartial")
            </div>
        </div>

        <div class="col-xl-10 col-lg-9">
            <div class="mb-3 px-2">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-medium shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4 px-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 mb-5 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <small class="opacity-75 d-block mb-1">Câu hỏi từ</small>
                        <h5 class="m-0 fw-bold"><i class="bi bi-person-circle me-2"></i>@Model.AuthorName</h5>
                    </div>
                    <div class="text-end">
                        <small class="opacity-75 d-block mb-1">Thời gian đăng</small>
                        <span class="fw-medium">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 py-2 me-2">@Model.CategoryName</span>
                    </div>
                    <h4 class="text-dark fw-normal mb-4 pb-4 border-bottom" style="line-height: 1.6;">@Model.Content</h4>
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold m-0"><i class="bi bi-chat-dots text-info me-2"></i>Bình luận (@Model.AnswerCount)</h5>
                        
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa hoàn toàn câu hỏi và mọi bình luận bên trong?');">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
                                <i class="bi bi-trash me-2"></i> Xóa toàn bộ Topic
                            </button>
                        </form>
                    </div>
                </div>

                @if (Model.Answers != null && Model.Answers.Any())
                {
                    <div class="list-group list-group-flush border-top">
                        @foreach (var ans in Model.Answers)
                        {
                            <div class="list-group-item p-4 bg-light border-bottom border-white" style="border-width: 4px !important;">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex flex-column">
                                        <h6 class="fw-bold text-primary mb-2">@ans.AuthorName <span class="text-muted fw-normal small ms-2"><i class="bi bi-clock me-1"></i>@ans.CreatedAt.ToString("HH:mm dd/MM/yyyy")</span></h6>
                                        <p class="text-dark mb-0" style="font-size: 1.05rem;">@ans.Content</p>
                                    </div>
                                    
                                    <form asp-action="DeleteAnswer" method="post">
                                        <input type="hidden" name="id" value="@ans.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 35px; height: 35px; padding: 0;" title="Xóa bình luận vi phạm" onclick="return confirm('Xóa câu trả lời này khỏi hệ thống?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-light rounded-bottom-4 border-top border-dashed text-muted">
                        <i class="bi bi-chat-square text-secondary opacity-50 display-4 d-block mb-3"></i>
                        Chưa có câu trả lời nào cho thảo luận này.
                    </div>
                }
            </div>
        </div>
    </div>
</div>