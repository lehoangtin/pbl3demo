@model StudyShare.Models.Question

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý Q&A</a></li>
            <li class="breadcrumb-item active">Chi tiết thảo luận</li>
        </ol>
    </nav>

    <div class="card border-primary mb-4">
        <div class="card-header bg-primary text-white">Câu hỏi từ: @Model.User?.FullName</div>
        <div class="card-body">
            <h5 class="card-title">@Model.Content</h5>
            <p class="card-text small text-muted">Đăng lúc: @Model.CreatedAt</p>
        </div>
    </div>

    <h4>💬 Các câu trả lời (@Model.Answers?.Count)</h4>
    <hr />

    @if (Model.Answers != null && Model.Answers.Any())
    {
        @foreach (var ans in Model.Answers)
        {
            <div class="card mb-2 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@ans.User?.FullName:</strong> @ans.Content
                        <br />
                        <small class="text-muted">@ans.CreatedAt</small>
                    </div>
                    <form asp-action="DeleteAnswer" method="post">
                        <input type="hidden" name="id" value="@ans.Id" />
                        <input type="hidden" name="questionId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xóa câu trả lời này?')">Xóa bài</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted italic">Chưa có câu trả lời nào.</p>
    }
</div>