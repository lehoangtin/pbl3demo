@model IEnumerable<StudyShare.ViewModels.QuestionViewModel>
@{
    ViewData["Title"] = "Quản lý thảo luận";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-bottom">
                    <h4 class="m-0 fw-bold text-primary"><i class="bi bi-chat-square-text me-2"></i>Danh sách câu hỏi (Q&A)</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 25%">Người đăng</th>
                                    <th style="width: 40%">Nội dung</th>
                                    <th class="text-center" style="width: 15%">Câu trả lời</th>
                                    <th class="text-end pe-4" style="width: 20%">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="fw-bold text-dark">@item.AuthorName</span><br />
                                                <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                            </td>
                                            <td>
                                                <div class="text-truncate text-dark" style="max-width: 300px;" title="@item.Content">
                                                    @item.Content
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info-subtle text-info border border-info rounded-pill px-3 py-1 shadow-sm">@item.AnswerCount</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group">
                                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white rounded-pill px-3 me-2 shadow-sm fw-bold">
                                                        <i class="bi bi-eye me-1"></i> Xem
                                                    </a>
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn câu hỏi này cùng các câu trả lời bên trong?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted border-0">
                                            <i class="bi bi-chat-square-text display-4 opacity-50 d-block mb-3"></i>
                                            Chưa có câu hỏi nào trên hệ thống.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>