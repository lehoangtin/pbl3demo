@model IEnumerable<StudyShare.ViewModels.CategoryViewModel>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row">
        <div class="col-md-3 col-lg-2 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9 col-lg-10">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-bottom">
                    <div class="row align-items-center g-3">
                        <div class="col-md-4">
                            <h4 class="m-0 fw-bold text-primary"><i class="bi bi-tags-fill me-2"></i>Danh mục</h4>
                        </div>
                        <div class="col-md-5">
                            <form asp-action="Index" method="get">
                                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                                    <span class="input-group-text bg-light border-0 ps-3">
                                        <i class="bi bi-search text-muted"></i>
                                    </span>
                                    <input type="text" name="searchString" class="form-control border-0 bg-light py-2" 
                                           placeholder="Tìm theo tên..." value="@ViewData["CurrentFilter"]" />
                                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                                    {
                                        <a asp-action="Index" class="btn btn-light border-0 d-flex align-items-center px-3" title="Xóa tìm kiếm">
                                            <i class="bi bi-x-lg text-muted"></i>
                                        </a>
                                    }
                                    <button type="submit" class="btn btn-primary px-3 fw-bold">Tìm</button>
                                </div>
                            </form>
                        </div>
                        <div class="col-md-3 text-md-end">
                            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                                <i class="bi bi-plus-lg me-1"></i> Thêm mới
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-semibold" style="width: 30%">TÊN DANH MỤC</th>
                                    <th class="text-muted fw-semibold" style="width: 50%">MÔ TẢ</th>
                                    <th class="text-end pe-4 text-muted fw-semibold" style="width: 20%">THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any()) {
                                    foreach (var item in Model) {
                                        <tr>
                                            <td class="fw-bold text-dark ps-4 py-3">
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                                    @item.Name
                                                </span>
                                            </td>
                                            <td class="text-muted small">
                                                @(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group shadow-sm rounded-3 overflow-hidden border">
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white border-0 py-2 px-3 text-warning" title="Sửa">
                                                        <i class="bi bi-pencil-fill"></i>
                                                    </a>
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa danh mục này có thể làm ảnh hưởng đến các tài liệu liên quan. Bạn chắc chắn chứ?')">
                                                        <button type="submit" class="btn btn-white border-0 py-2 px-3 text-danger border-start" title="Xóa">
                                                            <i class="bi bi-trash-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted border-0">
                                            <i class="bi bi-folder-x display-4 opacity-50 d-block mb-3"></i>
                                            <p class="mb-0">Không tìm thấy danh mục nào.</p>
                                            <a asp-action="Index" class="btn btn-link btn-sm mt-1">Xóa bộ lọc</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background-color: #fff; }
    .btn-white:hover { background-color: #f8f9fa; }
</style>