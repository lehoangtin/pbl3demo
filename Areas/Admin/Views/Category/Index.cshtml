@model IEnumerable<StudyShare.ViewModels.CategoryViewModel>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-primary">
                        <i class="bi bi-tags me-2"></i>Danh sách danh mục tài liệu
                    </h5>
                    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-plus-lg me-1"></i> Thêm mới
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4" style="width: 30%">Tên danh mục</th>
                                    <th style="width: 50%">Mô tả</th>
                                    <th style="width: 20%" class="text-end pe-4">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any()) {
                                    foreach (var item in Model) {
                                    <tr>
                                        <td class="fw-bold text-dark ps-4">
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                                @item.Name
                                            </span>
                                        </td>
                                        <td class="text-muted small">@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group">
                                                <a asp-action="Edit" asp-route-id="@item.Id" 
                                                   class="btn btn-sm btn-outline-warning rounded-circle me-2 shadow-sm" style="width: 35px; height: 35px;" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" 
                                                      onsubmit="return confirm('Xóa danh mục này có thể làm ảnh hưởng đến các tài liệu liên quan. Bạn chắc chắn chứ?')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 35px; height: 35px;" title="Xóa">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted border-0">
                                            <i class="bi bi-folder-x display-4 opacity-50 d-block mb-3"></i>
                                            Chưa có danh mục nào được tạo.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>