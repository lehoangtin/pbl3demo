@model IEnumerable<StudyShare.ViewModels.CategoryViewModel>
@{
    // Bạn có thể chọn 1 trong 2 layout bên dưới
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold text-primary">
            <i class="bi bi-tags me-2"></i>Danh sách danh mục tài liệu
        </h5>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm mới
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%">Tên danh mục</th>
                        <th style="width: 55%">Mô tả</th>
                        <th style="width: 20%" class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any()) {
                        foreach (var item in Model) {
                        <tr>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td class="text-muted small">@item.Description</td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-outline-warning rounded-circle me-2" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" 
                                          onsubmit="return confirm('Xóa danh mục này có thể làm ảnh hưởng đến các tài liệu liên quan. Bạn chắc chắn chứ?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        }
                    } else {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">Chưa có danh mục nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
