@model StudyShare.ViewModels.CategoryEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white p-4 border-bottom">
                    <h4 class="m-0 fw-bold text-warning"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa danh mục</h4>
                </div>
                <div class="card-body p-4 p-md-5 bg-light">
                    <form asp-action="Edit" method="post" class="bg-white p-4 rounded-4 shadow-sm border">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg rounded-3 shadow-sm border-0 bg-light" />
                            <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="mb-5">
                            <label asp-for="Description" class="form-label fw-bold text-dark">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control rounded-3 shadow-sm border-0 bg-light" rows="4"></textarea>
                        </div>
                        
                        <div class="d-flex justify-content-end gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 rounded-pill shadow-sm">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 rounded-pill text-dark fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.PartialAsync("_ValidationScriptsPartial");}
}