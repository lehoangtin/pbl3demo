@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<div class="container-fluid mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-speedometer2"></i> Dashboard Thống Kê</h2>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-primary border-4 shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Tổng người dùng</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalUsers</div>
                            <small class="text-danger">Đã khóa: @ViewBag.BannedUsers</small>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-people fa-2x text-gray-300 fs-1 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-success border-4 shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Tài liệu (Đã duyệt)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.ApprovedDocuments / @ViewBag.TotalDocuments</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-file-earmark-text fa-2x text-gray-300 fs-1 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-warning border-4 shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Tài liệu chờ duyệt</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.PendingDocuments</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-hourglass-split fa-2x text-gray-300 fs-1 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-info border-4 shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Thảo luận (Hỏi / Đáp)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalQuestions / @ViewBag.TotalAnswers</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-chat-dots fa-2x text-gray-300 fs-1 text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-dark text-white">
                    <h6 class="m-0 fw-bold"><i class="bi bi-trophy text-warning"></i> Top 5 Thành viên Năng nổ</h6>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Điểm</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in ViewBag.TopUsers)
                            {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td><span class="badge bg-warning text-dark"><i class="bi bi-coin"></i> @user.Points</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-warning text-dark">
                    <h6 class="m-0 fw-bold"><i class="bi bi-clock-history"></i> Cần duyệt gấp (5 mới nhất)</h6>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Tiêu đề</th>
                                <th>Người đăng</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentPendingDocs != null && ViewBag.RecentPendingDocs.Count > 0)
                            {
                                foreach (var doc in ViewBag.RecentPendingDocs)
                                {
                                    <tr>
                                        <td>@(doc.Title.Length > 30 ? doc.Title.Substring(0,30) + "..." : doc.Title)</td>
                                        <td>@doc.User?.FullName</td>
                                        <td>
                                            @* 🔥 ĐÃ SỬA DÒNG NÀY: Trỏ về trang Review của Admin *@
                                            <a asp-area="Admin" asp-controller="Document" asp-action="Review" asp-route-id="@doc.Id" class="btn btn-sm btn-info text-white">
                                                <i class="bi bi-eye"></i> Xem & Duyệt
                                            </a>                                       
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">Không có tài liệu nào chờ duyệt. Tuyệt vời!</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>