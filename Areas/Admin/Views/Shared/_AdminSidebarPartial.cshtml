<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
    <div class="card-header bg-dark text-white p-4 text-center border-0">
        <div class="mb-2">
            <i class="bi bi-shield-lock-fill display-4 text-warning"></i>
        </div>
        <h5 class="mb-0 fw-bold">QUẢN TRỊ VIÊN</h5>
        <small class="text-white-50">Hệ thống StudyShare</small>
    </div>

    <div class="list-group list-group-flush pb-3 bg-white">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-speedometer2 me-3 text-primary fs-5 align-middle"></i> Bảng điều khiển
        </a>
        
        <a asp-area="Admin" asp-controller="Document" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-file-earmark-check me-3 text-success fs-5 align-middle"></i> Duyệt tài liệu
        </a>
        
        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-people me-3 text-info fs-5 align-middle"></i> Quản lý người dùng
        </a>
        
        <a asp-area="Admin" asp-controller="User" asp-action="ReportedUsers" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-exclamation-triangle me-3 text-danger fs-5 align-middle"></i> Báo cáo vi phạm
        </a>
        
        <a asp-area="Admin" asp-controller="Question" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-chat-square-text me-3 text-secondary fs-5 align-middle"></i> Quản lý thảo luận
        </a>

        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-tags me-3 text-warning fs-5 align-middle"></i> Danh mục hệ thống
        </a>
        <a asp-area="Admin" asp-controller="User" asp-action="PendingReports" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-bold text-danger">
            <i class="bi bi-shield-exclamation me-3 fs-5 align-middle"></i> Chờ xử lý vi phạm
        </a>
        <a asp-area="Admin" asp-controller="Question" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-medium">
            <i class="bi bi-chat-square-text me-3 text-secondary fs-5 align-middle"></i> Quản lý thảo luận
        </a>
            <hr class="mx-4 my-2 text-muted opacity-25">

        <a asp-area="" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 fw-bold text-primary bg-light mt-2">
            <i class="bi bi-box-arrow-left me-2 fs-5 align-middle"></i> Về trang người dùng
        </a>
    </div>
</div>