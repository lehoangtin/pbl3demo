@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<div class="card border-0 shadow rounded-4 overflow-hidden mb-4 sticky-top" style="top: 20px; z-index: 1000;">
    <div class="card-header bg-dark text-white p-4 text-center border-0">
        <div class="mb-3">
            <i class="bi bi-shield-lock-fill display-4 text-warning"></i>
        </div>
        <h4 class="mb-0 fw-bold tracking-wide">QUẢN TRỊ VIÊN</h4>
        <small class="text-white-50 fs-6">Hệ thống StudyShare</small>
    </div>

    <div class="list-group list-group-flush pb-4 bg-white p-3 text-nowrap">
        
        <a asp-area="Admin" asp-controller="Home" asp-action="Index"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "Home" ? "active shadow" : "text-secondary hover-bg-light")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-speedometer2 me-3 fs-5 @(currentController == "Home" ? "" : "text-primary")"></i> 
                <span class="fw-bold fs-6 text-truncate">Bảng điều khiển</span>
            </div>
        </a>

        <a asp-area="Admin" asp-controller="Document" asp-action="Index"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "Document" ? "active shadow" : "text-secondary hover-bg-light")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-file-earmark-check me-3 fs-5 @(currentController == "Document" ? "" : "text-success")"></i> 
                <span class="fw-bold fs-6 text-truncate">Quản lý tài liệu</span>
            </div>
        </a>

        <a asp-area="Admin" asp-controller="Question" asp-action="Index"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "Question" ? "active shadow" : "text-secondary hover-bg-light")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-chat-square-text me-3 fs-5 @(currentController == "Question" ? "" : "text-info")"></i> 
                <span class="fw-bold fs-6 text-truncate">Quản lý thảo luận</span>
            </div>
        </a>

        <a asp-area="Admin" asp-controller="Category" asp-action="Index"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "Category" ? "active shadow" : "text-secondary hover-bg-light")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-tags me-3 fs-5 @(currentController == "Category" ? "" : "text-warning")"></i> 
                <span class="fw-bold fs-6 text-truncate">Danh mục</span>
            </div>
        </a>

        <hr class="mx-3 my-3 text-muted opacity-25">
        <small class="px-3 text-muted fw-black text-uppercase mb-2 d-block" style="font-size: 0.8rem; letter-spacing: 1px;">Thành viên</small>

        <a asp-area="Admin" asp-controller="User" asp-action="Index"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "User" && (currentAction == "Index" || currentAction == "Details") ? "active shadow" : "text-secondary hover-bg-light")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-people me-3 fs-5 @(currentController == "User" && (currentAction == "Index" || currentAction == "Details") ? "" : "text-primary")"></i> 
                <span class="fw-bold fs-6 text-truncate">Người dùng</span>
            </div>
        </a>

        <a asp-area="Admin" asp-controller="User" asp-action="PendingReports"
           class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
           @(currentController == "User" && (currentAction == "PendingReports" || currentAction == "ViewReports") ? "active bg-danger text-white shadow" : "text-danger hover-bg-danger-subtle")">
            <div class="d-flex align-items-center overflow-hidden">
                <i class="bi bi-shield-exclamation me-3 fs-5"></i> 
                <span class="fw-bold fs-6 text-truncate">Xử lý vi phạm</span>
            </div>
        </a>

        @if (User.IsInRole("SuperAdmin"))
        {
            <a asp-area="Admin" asp-controller="User" asp-action="ManageRoles"
               class="list-group-item list-group-item-action border-0 px-3 py-3 rounded-3 mb-2 transition-all
               @(currentAction == "ManageRoles" ? "active bg-dark text-white shadow" : "text-dark hover-bg-light")">
                <div class="d-flex align-items-center overflow-hidden">
                    <i class="bi bi-key me-3 fs-5 @(currentAction == "ManageRoles" ? "" : "text-warning")"></i> 
                    <span class="fw-bold fs-6 text-truncate">Phân quyền</span>
                </div>
            </a>
        }
        
        <div class="mt-4 px-2">
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm hover-lift text-truncate">
                <i class="bi bi-box-arrow-left me-2 fs-6"></i> Thoát Admin
            </a>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 900; }
    .transition-all { transition: all 0.25s ease-in-out; }
    .hover-bg-light:hover { background-color: #f1f3f5; transform: translateX(5px); }
    .hover-bg-danger-subtle:hover { background-color: #ffeef0; color: #dc3545 !important; transform: translateX(5px); }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important; }
    .tracking-wide { letter-spacing: 1.5px; }
    .list-group-item.active { border-radius: 12px !important; }
</style>