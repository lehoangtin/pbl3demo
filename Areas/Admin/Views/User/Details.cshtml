@model StudyShare.ViewModels.UserViewModel
@{
    ViewData["Title"] = "Hồ sơ: " + Model.FullName;
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách</a>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
                <div class="bg-primary px-5 py-4 text-white d-flex flex-column flex-md-row align-items-center position-relative">
                    <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/default-avatar.png" : Model.Avatar)" 
                         class="rounded-circle border border-4 border-white shadow mb-3 mb-md-0 z-1" 
                         style="width: 120px; height: 120px; object-fit: cover;">
                    <div class="ms-md-4 text-center text-md-start z-1">
                        <h2 class="fw-bold mb-1">@Model.FullName</h2>
                        <p class="mb-2 opacity-75 fs-5">@Model.Email</p>
                        <div class="d-flex gap-2 justify-content-center justify-content-md-start">
                            <span class="badge bg-white text-primary rounded-pill px-3 py-2"><i class="bi bi-coin me-1"></i> @Model.Points điểm</span>
                            @if (Model.IsBanned) {
                                <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-lock-fill me-1"></i> Đã khóa</span>
                            } else {
                                <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> Đang hoạt động</span>
                            }
                        </div>
                    </div>
                    <i class="bi bi-person-bounding-box position-absolute end-0 bottom-0 text-white opacity-10" style="font-size: 8rem; transform: translate(10%, 20%);"></i>
                </div>
                
                <div class="card-body p-4 bg-light d-flex justify-content-end">
                    <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post">
                        @if (Model.IsBanned) {
                            <button type="submit" class="btn btn-success rounded-pill px-4 shadow-sm fw-bold"><i class="bi bi-unlock-fill me-2"></i>Mở khóa tài khoản</button>
                        } else {
                            <button type="submit" class="btn btn-outline-danger rounded-pill px-4 shadow-sm" onclick="return confirm('Bạn có chắc muốn khóa người dùng này?');"><i class="bi bi-lock-fill me-2"></i>Khóa tài khoản</button>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>