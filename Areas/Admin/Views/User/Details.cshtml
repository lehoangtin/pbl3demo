@model StudyShare.ViewModels.UserViewModel
@{
    ViewData["Title"] = "Chi tiết người dùng";
    bool isBanned = Model.IsBanned || Model.WarningCount >= 3;
}

<div class="container-fluid mt-4 px-4 mb-5">
    <div class="row">
        <div class="col-md-3 col-lg-2 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9 col-lg-10">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Quản lý người dùng</a></li>
                    <li class="breadcrumb-item active">Hồ sơ người dùng</li>
                </ol>
            </nav>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 text-center p-4 h-100">
                        <div class="position-relative d-inline-block mx-auto mb-3 mt-2">
                            <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/default-avatar.png" : Model.Avatar)" 
                                 class="rounded-circle border border-4 @(isBanned ? "border-danger" : "border-success") shadow" 
                                 width="150" height="150" style="object-fit: cover;">
                            <span class="position-absolute bottom-0 end-0 badge rounded-pill @(isBanned ? "bg-danger" : "bg-success") border border-3 border-white p-2">
                                <span class="visually-hidden">Trạng thái</span>
                            </span>
                        </div>
                        <h4 class="fw-bold mb-1 mt-2 text-dark">@Model.FullName</h4>
                        <p class="text-muted mb-4">@Model.Email</p>
                        
                        <div class="d-flex justify-content-center gap-3 mb-4">
                            <div class="bg-light rounded-4 px-4 py-2 border shadow-sm">
                                <h4 class="mb-0 fw-bold text-primary">@Model.Points</h4>
                                <small class="text-muted fw-medium">Điểm</small>
                            </div>
                            <div class="bg-light rounded-4 px-4 py-2 border shadow-sm">
                                <h4 class="mb-0 fw-bold @(Model.WarningCount >= 3 ? "text-danger" : "text-warning")">@Model.WarningCount</h4>
                                <small class="text-muted fw-medium">Cảnh cáo</small>
                            </div>
                        </div>

                        <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post" class="w-100 mt-auto">
                            <button type="submit" class="btn @(isBanned ? "btn-success" : "btn-danger") w-100 rounded-pill fw-bold py-2 shadow-sm">
                                <i class="bi @(isBanned ? "bi-unlock-fill" : "bi-lock-fill") me-2"></i>
                                @(isBanned ? "Mở khóa tài khoản" : "Khóa tài khoản này")
                            </button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                        <h5 class="fw-bold mb-4 border-bottom pb-3 text-primary"><i class="bi bi-person-lines-fill me-2"></i>Thông tin chi tiết</h5>
                        
                        <div class="row g-4 mb-2">
                            <div class="col-sm-6">
                                <label class="text-muted small d-block mb-1">Họ và tên</label>
                                <span class="fw-bold text-dark fs-6">@Model.FullName</span>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted small d-block mb-1">Địa chỉ Email</label>
                                <span class="fw-bold text-dark fs-6">@Model.Email</span>
                            </div>
                            <div class="col-sm-12">
                                <label class="text-muted small d-block mb-1">Trạng thái hệ thống</label>
                                @if (isBanned) {
                                    <span class="text-danger fw-bold fs-6"><i class="bi bi-shield-slash-fill me-1"></i> Đang bị khóa</span>
                                } else {
                                    <span class="text-success fw-bold fs-6"><i class="bi bi-shield-check me-1"></i> Đang hoạt động</span>
                                }
                            </div>
                        </div>

                        <h5 class="fw-bold mb-4 mt-5 border-bottom pb-3 text-primary"><i class="bi bi-grid-fill me-2"></i>Quản lý nội dung</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 border rounded-4 bg-light d-flex flex-column h-100">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-primary text-white rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-file-earmark-text fs-5"></i>
                                        </div>
                                        <span class="fw-bold text-dark">Tài liệu đã đăng</span>
                                    </div>
                                    <a asp-area="Admin" asp-controller="Document" asp-action="Index" asp-route-searchString="@Model.FullName" 
                                       class="btn btn-outline-primary rounded-pill mt-auto w-100 fw-bold">
                                       <i class="bi bi-box-arrow-up-right me-1"></i> Xem danh sách
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded-4 bg-light d-flex flex-column h-100">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-info text-white rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-chat-square-text fs-5"></i>
                                        </div>
                                        <span class="fw-bold text-dark">Câu hỏi cộng đồng</span>
                                    </div>
                                    <a asp-area="Admin" asp-controller="Question" asp-action="Index" asp-route-searchString="@Model.FullName" 
                                       class="btn btn-outline-info text-dark rounded-pill mt-auto w-100 fw-bold">
                                       <i class="bi bi-box-arrow-up-right me-1"></i> Xem danh sách
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="mt-auto pt-5">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 border fw-medium text-dark shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>