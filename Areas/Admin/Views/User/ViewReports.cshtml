@model IEnumerable<StudyShare.ViewModels.ReportViewModel>
@{
    ViewData["Title"] = "Chi tiết báo cáo";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="ReportedUsers" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách vi phạm</a>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4 border-danger border-start border-4">
                <div class="card-body p-4">
                    <h4 class="m-0 text-dark">Báo cáo vi phạm đối với: <span class="text-danger fw-bold">@ViewBag.TargetUser</span></h4>
                </div>
            </div>

            @if (Model != null && Model.Any()) {
                <div class="row g-4">
                    @foreach (var r in Model) {
                        <div class="col-12">
                            <div class="card shadow-sm border-0 rounded-4">
                                <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center border-bottom">
                                    <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-flag-fill me-2"></i>Lý do: @r.Reason</h5>
                                    <span class="text-muted small"><i class="bi bi-clock me-1"></i>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div class="card-body p-4 bg-light">
                                    <div class="mb-3 text-dark">
                                        <small class="text-muted d-block fw-bold mb-2">Người báo cáo:</small>
                                        <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="bi bi-person me-1"></i> @r.ReporterName</span>
                                    </div>
                                    <div class="d-flex justify-content-end pt-3 border-top">
                                        <form asp-area="Admin" asp-controller="User" asp-action="ConfirmReport" method="post">
                                            <input type="hidden" name="reportId" value="@r.Id" />
                                            <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold" onclick="return confirm('Xác nhận vi phạm? Người dùng sẽ bị phạt.');">
                                                <i class="bi bi-gavel me-2"></i> Xác nhận & Xử phạt
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            } else {
                <div class="text-center py-5 bg-light rounded-4 border border-dashed text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                    Chưa có chi tiết báo cáo nào.
                </div>
            }
        </div>
    </div>
</div>