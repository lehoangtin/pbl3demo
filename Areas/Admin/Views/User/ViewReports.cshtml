@model IEnumerable<StudyShare.ViewModels.ReportViewModel>
@{
    ViewData["Title"] = "Chi tiết báo cáo";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="ReportedUsers" class="text-decoration-none text-muted">Quay lại danh sách vi phạm</a>
            </div>

            <div class="card shadow-sm border-0 mb-4 border-danger border-start border-4">
                <div class="card-body p-4">
                    <h4 class="m-0 text-dark">Báo cáo vi phạm đối với: <span class="text-danger fw-bold">@ViewBag.TargetUser</span></h4>
                </div>
            </div>

            @if (Model != null && Model.Any()) {
                <div class="row g-3">
                    @foreach (var r in Model) {
                        <div class="col-12">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center border-bottom">
                                    <h5 class="mb-0 fw-bold text-danger">Lý do: @r.Reason</h5>
                                    <span class="text-muted small">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div class="card-body p-4 bg-light">
                                    <div class="mb-3 text-dark">
                                        <small class="text-muted d-block fw-bold mb-1">Người báo cáo:</small>
                                        <span class="badge bg-secondary px-3 py-2">@r.ReporterName</span>
                                    </div>
                                    
                                    <div class="mb-3 p-2 border rounded bg-white">
                                        <small class="text-muted d-block">Nội dung liên quan:</small>
                                        @if (r.DocumentId.HasValue) { <strong>Tài liệu #@r.DocumentId</strong> }
                                        else if (r.QuestionId.HasValue) { <strong>Câu hỏi #@r.QuestionId</strong> }
                                        else { <strong>Nội dung khác</strong> }
                                    </div>

                                    @if (!r.IsResolved) {
                                        <div class="d-flex justify-content-end pt-3 border-top">
                                            <form asp-area="Admin" asp-controller="User" asp-action="Penalize" method="post" class="d-flex align-items-center">
                                                <input type="hidden" name="userId" value="@ViewBag.TargetUserId" />
                                                <input type="hidden" name="reportId" value="@r.Id" />
                                                
                                                <div class="input-group input-group-sm me-3" style="width: 130px;">
                                                    <span class="input-group-text">Trừ điểm</span>
                                                    <input type="number" name="pointsDeducted" value="10" class="form-control" />
                                                </div>

                                                <button type="submit" class="btn btn-danger fw-bold me-2" onclick="return confirm('Xác nhận xử phạt?');">
                                                    Xử phạt
                                                </button>
                                            </form>

                                            <form asp-action="ResolveReport" method="post">
                                                <input type="hidden" name="reportId" value="@r.Id" />
                                                <button type="submit" class="btn btn-outline-secondary">Bỏ qua</button>
                                            </form>
                                        </div>
                                    } else {
                                        <div class="alert alert-info mb-0 py-2">
                                            Kết quả: @(r.ActionTaken ?? "Đã xử lý")
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            } else {
                <div class="text-center py-5 bg-light rounded border border-dashed">
                    Chưa có chi tiết báo cáo nào.
                </div>
            }
        </div>
    </div>
</div>