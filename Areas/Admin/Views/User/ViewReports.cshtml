@model IEnumerable<StudyShare.Models.Report>
@{
    ViewData["Title"] = "Chi tiết báo cáo vi phạm";
}

<div class="container mt-4">
    <h3>Báo cáo vi phạm đối với: <span class="text-danger">@ViewBag.TargetUser</span></h3>
    <hr />

    <div class="list-group">
        @foreach (var r in Model) {
            <div class="list-group-item mb-3 shadow-sm border-start border-danger border-4 p-4">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1 text-primary">Lý do: @r.Reason</h5>
                    <small class="text-muted">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <div class="my-3">
                    <strong>Nội dung bị báo cáo:</strong> 
                    <div class="p-2 bg-light rounded mt-1">
                        @if (r.QuestionId != null) {
                            <span>Câu hỏi: <em>"@r.Question?.Content"</em></span>
                        } else if (r.AnswerId != null) {
                            <span>Câu trả lời: <em>"@r.Answer?.Content"</em></span>
                        } else {
                            <span>Tài liệu ID: @r.DocumentId</span>
                        }
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">Người báo cáo: @r.Reporter?.FullName (@r.Reporter?.Email)</small>
                    
                    @* 🔥 Nút xác nhận xử phạt dành cho Admin *@
                    <form asp-area="Admin" asp-controller="User" asp-action="ConfirmReport" method="post">
                        <input type="hidden" name="reportId" value="@r.Id" />
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Xác nhận vi phạm? Người dùng sẽ bị trừ 5đ và nhận 1 cảnh cáo.')">
                            <i class="bi bi-check-circle me-1"></i> Xác nhận vi phạm & Phạt
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
    
    <div class="mt-3">
        <a asp-action="ReportedUsers" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>