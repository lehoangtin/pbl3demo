@model IEnumerable<StudyShare.ViewModels.ReportViewModel>
@{
    ViewData["Title"] = "Hồ sơ vi phạm cá nhân";
    // Lấy tên người dùng từ báo cáo hoặc từ ViewBag để tránh bị trống
    var targetUserName = Model.FirstOrDefault()?.TargetUserName ?? ViewBag.TargetUser ?? "Người dùng";
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row">
        <div class="col-md-3 col-lg-2 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9 col-lg-10">
            <div class="mb-3">
                <a asp-action="PendingReports" class="btn btn-light border rounded-pill shadow-sm fw-bold text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4 border-danger border-start border-4">
                <div class="card-body p-4">
                    <h4 class="m-0 text-dark">Hồ sơ báo cáo đối với: <span class="text-danger fw-bold">@targetUserName</span></h4>
                </div>
            </div>

            @if (Model != null && Model.Any()) {
                <div class="row g-4">
                    @foreach (var r in Model.OrderByDescending(x => x.CreatedAt)) {
                        <div class="col-12">
                            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                                <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center border-bottom">
                                    <h5 class="mb-0 fw-bold text-danger">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Lý do: @r.Reason
                                    </h5>
                                    <span class="text-muted small"><i class="bi bi-clock me-1"></i>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                
                                <div class="card-body p-4 bg-light">
                                    <div class="row">
                                        <div class="col-md-12 mb-3">
                                            <small class="text-muted d-block fw-bold mb-2">Nguồn báo cáo:</small>
                                            @if (r.Reason.Contains("[HỆ THỐNG AI]")) {
                                                <span class="badge bg-info-subtle text-info border border-info px-3 py-2 rounded-pill fs-6">
                                                    <i class="bi bi-robot me-1"></i> Hệ thống kiểm duyệt AI
                                                </span>
                                            } else {
                                                <span class="badge bg-secondary px-3 py-2 rounded-pill fs-6">
                                                    <i class="bi bi-person-fill me-1"></i> @r.ReporterName
                                                </span>
                                            }
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <div class="mb-3 p-3 border rounded bg-white shadow-sm">
                                                <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.75rem;">Nội dung bị báo cáo:</small>
                                                
                                                <div class="p-3 bg-light rounded border-start border-4 border-warning mb-3 text-dark shadow-sm" style="font-style: italic;">
                                                    @if (!string.IsNullOrEmpty(r.TargetContent)) {
                                                        <i class="bi bi-quote fs-4 text-muted"></i>
                                                        <span>@r.TargetContent</span>
                                                    } else {
                                                        <span class="text-muted">Không có bản xem trước nội dung văn bản (Có thể là file tài liệu).</span>
                                                    }
                                                </div>

                                                <div class="d-flex gap-2 align-items-center">
                                                    @if (r.DocumentId.HasValue) { 
                                                        <a asp-area="User" asp-controller="Document" asp-action="Details" asp-route-id="@r.DocumentId" target="_blank" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">
                                                            <i class="bi bi-eye-fill me-1"></i> Xem Tài liệu
                                                        </a> 
                                                    }
                                                    else if (r.QuestionId.HasValue) { 
                                                        <a asp-area="User" asp-controller="Question" asp-action="Details" asp-route-id="@r.QuestionId" target="_blank" class="btn btn-sm btn-info text-white rounded-pill px-3 fw-bold">
                                                            <i class="bi bi-eye-fill me-1"></i> Xem Câu hỏi
                                                        </a> 
                                                    }
                                                    else if (r.AnswerId.HasValue) {
                                                        <span class="badge bg-dark px-3 py-2 rounded-pill">Bình luận #@r.AnswerId</span>
                                                    }
                                                </div>

                                                @if (!string.IsNullOrEmpty(r.Description)) {
                                                    <div class="mt-3 p-2 bg-warning-subtle rounded border-start border-3 border-warning small text-dark">
                                                        <strong>Ghi chú từ người báo cáo:</strong> @r.Description
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    @if (!r.IsResolved) {
                                        <div class="d-flex justify-content-end pt-3 border-top mt-2">
                                            <form asp-area="Admin" asp-controller="User" asp-action="Penalize" method="post" class="me-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@ViewBag.TargetUserId" />
                                                <input type="hidden" name="reportId" value="@r.Id" />
                                                
                                                <div class="d-flex align-items-center">
                                                    <div class="input-group input-group-sm me-2" style="width: 140px;">
                                                        <span class="input-group-text bg-white">Phạt</span>
                                                        <input type="number" name="pointsDeducted" value="10" class="form-control" />
                                                    </div>
                                                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" onclick="return confirm('Xác nhận XỬ PHẠT người dùng này?');">
                                                        <i class="bi bi-hammer me-1"></i> Phạt
                                                    </button>
                                                </div>
                                            </form>

                                            <form asp-area="Admin" asp-controller="User" asp-action="DismissReport" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="reportId" value="@r.Id" />
                                                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">Bỏ qua</button>
                                            </form>
                                        </div>
                                    } 
                                    else {
                                        <div class="alert alert-info mb-0 mt-3 py-3 border-0 shadow-sm rounded-3 d-flex align-items-center">
                                            <i class="bi bi-info-circle-fill fs-4 me-3 text-info"></i>
                                            <div>
                                                <strong class="d-block mb-1 text-dark">Trạng thái: Đã xử lý</strong>
                                                <span class="text-muted small">Kết quả: @(r.ActionTaken ?? "Quản trị viên đã giải quyết")</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            } else {
                <div class="text-center py-5 bg-white rounded-4 shadow-sm border-0 border-dashed border-2">
                    <i class="bi bi-shield-check display-1 text-success opacity-50 d-block mb-3"></i>
                    <h4 class="text-dark fw-bold">Hồ sơ trong sạch</h4>
                    <p class="text-muted mb-0">Hiện không có báo cáo nào đối với người dùng này.</p>
                </div>
            }
        </div>
    </div>
</div>