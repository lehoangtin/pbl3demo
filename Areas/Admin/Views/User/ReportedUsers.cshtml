@model IEnumerable<StudyShare.DTOs.Responses.UserResponse>
@{
    ViewData["Title"] = "Quản lý vi phạm";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger"><i class="bi bi-shield-exclamation"></i> Quản lý vi phạm & Báo cáo</h2>
    </div>

    <ul class="nav nav-tabs mb-4 border-bottom border-2" id="reportTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold fs-5 text-danger" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                <i class="bi bi-exclamation-triangle-fill"></i> Cần xử lý 
                <span class="badge bg-danger rounded-pill ms-1">@ViewBag.PendingReports?.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold fs-5 text-success" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">
                <i class="bi bi-clock-history"></i> Lịch sử xử lý
                <span class="badge bg-success rounded-pill ms-1">@ViewBag.HistoryReports?.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="reportTabContent">
        <div class="tab-pane fade show active" id="pending" role="tabpanel">
            <div class="card shadow border-danger border-start border-4">
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Người bị báo cáo</th>
                                <th>Nguồn báo cáo</th>
                                <th>Lý do vi phạm</th>
                                <th>Thời gian</th>
                                <th>Thao tác Admin</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.PendingReports != null && ViewBag.PendingReports.Count > 0)
                            {
                                foreach (var item in ViewBag.PendingReports)
                                {
                                    <tr>
                                        @* 🔥 ĐÃ SỬA: Đổi ReportedUser thành Target *@
                                        <td><strong>@item.Target?.FullName</strong><br><small class="text-muted">@item.Target?.Email</small></td>
                                        <td>
                                            @* Nếu Reporter = null => Là do AI tự quét *@
                                            @if (item.Reporter == null)
                                            {
                                                <span class="badge bg-dark text-white p-2"><i class="bi bi-robot"></i> AI Tự động</span>
                                            }
                                            else
                                            {
                                                <span>@item.Reporter.FullName</span>
                                            }
                                        </td>
                                        <td><span class="text-danger fw-bold">@item.Reason</span></td>
                                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @* 🔥 ĐÃ SỬA: Đổi ReportedUserId thành TargetUserId *@
                                            <form asp-action="BanUser" asp-route-userId="@item.TargetUserId" asp-route-reportId="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Khóa tài khoản này ngay lập tức?');">
                                                <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-lock-fill"></i> Khóa Acc</button>
                                            </form>
                                            <form asp-action="DismissReport" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-secondary"><i class="bi bi-x-circle"></i> Bỏ qua</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-5"><i class="bi bi-check-circle text-success fs-1"></i><br>Hệ thống sạch bóng vi phạm!</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="history" role="tabpanel">
            <div class="card shadow border-success border-start border-4">
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Tài khoản</th>
                                <th>Nguồn</th>
                                <th>Nội dung bị báo cáo</th>
                                <th>Kết quả từ Admin</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.HistoryReports != null && ViewBag.HistoryReports.Count > 0)
                            {
                                foreach (var item in ViewBag.HistoryReports)
                                {
                                    <tr>
                                        @* 🔥 ĐÃ SỬA: Đổi ReportedUser thành Target *@
                                        <td>@item.Target?.FullName</td>
                                        <td>
                                            @(item.Reporter != null ? item.Reporter.FullName : "AI Hệ thống")
                                        </td>
                                        <td class="text-muted">@item.Reason</td>
                                        <td>
                                            <span class="badge p-2 @(item.ActionTaken != null && item.ActionTaken.Contains("Khóa") ? "bg-danger" : "bg-secondary")">
                                                <i class="bi @(item.ActionTaken != null && item.ActionTaken.Contains("Khóa") ? "bi-lock" : "bi-check")"></i> @(item.ActionTaken ?? "Đã xử lý")
                                            </span>
                                            <br/><small class="text-muted">Lúc: @item.CreatedAt.ToString("dd/MM/yy")</small>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-5">Chưa có lịch sử xử lý nào.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>