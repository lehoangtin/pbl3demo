@model IEnumerable<StudyShare.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Quản lý vi phạm";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <h4 class="fw-bold text-danger mb-4"><i class="bi bi-shield-exclamation me-2"></i>Quản lý vi phạm & Báo cáo</h4>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-3">
                    <h6 class="m-0 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Người dùng bị cảnh cáo / báo cáo nhiều nhất</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3">Người vi phạm</th>
                                    <th>Cảnh cáo</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Thao tác Admin</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model.OrderByDescending(x => x.WarningCount))
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark fs-6">@item.FullName</div>
                                                <small class="text-muted">@item.Email</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fs-6">
                                                    <i class="bi bi-exclamation-circle-fill me-1"></i> @item.WarningCount Lần
                                                </span>
                                            </td>
                                            <td>
                                                @(item.IsBanned ? Html.Raw("<span class='badge bg-danger'>Đã khóa</span>") : Html.Raw("<span class='badge bg-success'>Đang mở</span>"))
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-action="ViewReports" asp-route-userId="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm fw-bold">
                                                    <i class="bi bi-card-list me-1"></i> Xem các báo cáo
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-5 border-0"><i class="bi bi-check-circle text-success fs-1 d-block mb-3"></i>Hệ thống sạch bóng vi phạm!</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>