@model StudyShare.ViewModels.ReportDashboardViewModel
@{
    ViewData["Title"] = "Xử lý vi phạm";
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row">
        <div class="col-xl-3 col-lg-4 mb-4 d-none d-lg-block">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-xl-9 col-lg-8">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4 animate__animated animate__fadeIn">
                    <i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i> @TempData["Success"]
                    <button type="button" class="btn-close mt-1" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5 align-middle"></i> @TempData["Error"]
                    <button type="button" class="btn-close mt-1" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white pt-4 pb-3 border-bottom-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <h4 class="fw-bold text-danger mb-3 mb-md-0">
                        <i class="bi bi-shield-exclamation me-2"></i>Trung tâm xử lý vi phạm
                    </h4>

                    <ul class="nav nav-pills bg-light p-1 rounded-pill shadow-sm" id="reportTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active rounded-pill fw-bold px-4 transition-all" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-pane" type="button" role="tab">
                                Chờ xử lý 
                                @if (Model.PendingReports.Any()) {
                                    <span class="badge bg-danger rounded-pill ms-1">@Model.PendingReports.Count()</span>
                                }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold text-secondary px-4 transition-all" id="resolved-tab" data-bs-toggle="tab" data-bs-target="#resolved-pane" type="button" role="tab">
                                Lịch sử xử lý
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-0 border-top">
                    <div class="tab-content" id="reportTabsContent">
                        
                        <div class="tab-pane fade show active" id="pending-pane" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Bị báo cáo</th>
                                            <th class="py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Người báo cáo</th>
                                            <th class="py-3 text-muted text-uppercase" style="width: 35%; font-size: 0.85rem;">Lý do / Nội dung</th>
                                            <th class="text-end pe-4 py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.PendingReports.Any()) {
                                            foreach (var item in Model.PendingReports) {
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="fw-bold text-danger fs-6">@item.TargetUserName</div>
                                                        <small class="text-muted">ID: @item.TargetUserId.Substring(0, 8)...</small>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><i class="bi bi-person-fill text-secondary me-1"></i> @item.ReporterName</span>
                                                    </td>
                                                    <td>
                                                        <div class="fw-bold text-dark text-truncate mb-1" style="max-width: 300px;" title="@item.Reason">@item.Reason</div>
                                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <div class="btn-group shadow-sm">
                                                            <form asp-area="Admin" asp-controller="User" asp-action="Penalize" method="post" class="m-0" onsubmit="return confirm('Bạn chắc chắn muốn XỬ PHẠT (Trừ 10 điểm, +1 gậy cảnh cáo) tài khoản này?');">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="userId" value="@item.TargetUserId" />
                                                                <input type="hidden" name="reportId" value="@item.Id" />
                                                                <button type="submit" class="btn btn-sm btn-danger rounded-start-pill px-3 fw-bold border-0" title="Phạt người này">
                                                                    <i class="bi bi-hammer"></i> Phạt
                                                                </button>
                                                            </form>
                                                            
                                                            <form asp-area="Admin" asp-controller="User" asp-action="DismissReport" method="post" class="m-0" onsubmit="return confirm('Bạn chắc chắn muốn BỎ QUA báo cáo này?');">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="reportId" value="@item.Id" />
                                                                <button type="submit" class="btn btn-sm btn-light border-top border-bottom border-end-0 px-3 fw-bold text-secondary" title="Bỏ qua">
                                                                    Bỏ qua
                                                                </button>
                                                            </form>
                                                            
                                                            <a asp-action="ViewReports" asp-route-id="@item.TargetUserId" class="btn btn-sm btn-light border rounded-end-pill px-3 fw-bold text-primary" title="Xem chi tiết hồ sơ vi phạm">
                                                                Chi tiết
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        } else {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 bg-light">
                                                    <img src="https://cdn-icons-png.flaticon.com/512/190/190411.png" width="80" class="opacity-25 mb-3" alt="Empty">
                                                    <h5 class="text-muted fw-bold">Thật yên bình!</h5>
                                                    <p class="text-muted mb-0">Không có báo cáo nào đang chờ bạn xử lý.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="resolved-pane" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Người vi phạm</th>
                                            <th class="py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Phát hiện bởi</th>
                                            <th class="py-3 text-muted text-uppercase" style="width: 40%; font-size: 0.85rem;">Nội dung & Hình phạt</th>
                                            <th class="text-end pe-4 py-3 text-muted text-uppercase" style="font-size: 0.85rem;">Thời gian</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ResolvedReports.Any()) {
                                            @foreach (var item in Model.ResolvedReports) {
                                                <tr>
                                                    <td class="ps-4 py-3 fw-bold text-dark fs-6">@item.TargetUserName</td>
                                                    <td>
                                                        @if (item.Reason.Contains("[HỆ THỐNG AI]")) {
                                                            <span class="badge bg-info text-white rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-robot me-1"></i> AI System</span>
                                                        } else {
                                                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><i class="bi bi-person text-secondary me-1"></i> @item.ReporterName</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <div class="fw-bold text-dark text-truncate mb-1" style="max-width: 350px;">@item.Reason</div>
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-2">
                                                            <i class="bi bi-hammer me-1"></i> @item.ActionTaken
                                                        </span>
                                                    </td>
                                                    <td class="text-end pe-4 text-muted small fw-medium">
                                                        @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                    </td>
                                                </tr>
                                            }
                                        } else {
                                            <tr>
                                                <td colspan="4" class="text-center py-5">
                                                    <i class="bi bi-archive text-muted opacity-25 display-3 d-block mb-3"></i>
                                                    <p class="text-muted mb-0 fw-medium">Chưa có lịch sử xử lý vi phạm nào.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link.active { background-color: #0d6efd; color: white !important; box-shadow: 0 2px 4px rgba(13, 110, 253, 0.3); }
    .nav-pills .nav-link { color: #6c757d; }
    .nav-pills .nav-link:hover:not(.active) { background-color: #e9ecef; }
</style>