@model IEnumerable<StudyShare.ViewModels.ReportViewModel>
@{
    ViewData["Title"] = "Danh sách báo cáo chờ xử lý";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>
        <div class="col-md-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary">Tất cả báo cáo vi phạm mới</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Người gửi</th>
                                <th>Người bị báo cáo</th>
                                <th>Lý do</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model) {
                                <tr>
                                    <td class="small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.ReporterName</td>
                                    <td><span class="text-danger fw-bold">@item.TargetName</span></td>
                                    <td>@item.Reason</td>
                                    <td class="text-end">
                                        <form asp-action="Penalize" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@item.TargetUserId" />
                                            <input type="hidden" name="reportId" value="@item.Id" />
                                            <input type="hidden" name="pointsDeducted" value="10" />
                                            <button type="submit" class="btn btn-sm btn-danger">Phạt nhanh</button>
                                        </form>
                                        <a asp-action="ViewReports" asp-route-userId="@item.TargetUserId" class="btn btn-sm btn-primary">Xem chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>