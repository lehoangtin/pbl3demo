@model IEnumerable<StudyShare.ViewModels.UserViewModel>
@{ 
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row">
        <div class="col-md-3 col-lg-2 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9 col-lg-10">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4 animate__animated animate__fadeIn">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-bottom">
                    <div class="row align-items-center g-3">
                        <div class="col-md-6">
                            <h4 class="m-0 fw-bold text-primary">
                                <i class="bi bi-people-fill me-2"></i>Quản lý tài khoản
                            </h4>
                            <p class="text-muted small mb-0 mt-1">Tổng cộng: @Model.Count() người dùng trên hệ thống</p>
                        </div>
                        <div class="col-md-6">
                            <form asp-area="Admin" asp-controller="User" asp-action="Index" method="get">
                                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                                    <span class="input-group-text bg-light border-0 ps-3">
                                        <i class="bi bi-search text-muted"></i>
                                    </span>
                                    <input type="text" name="searchString" class="form-control border-0 bg-light py-2" 
                                           placeholder="Tìm theo tên hoặc email..." value="@ViewData["CurrentFilter"]" />
                                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                                    {
                                        <a asp-action="Index" class="btn btn-light border-0 d-flex align-items-center px-3" title="Xóa tìm kiếm">
                                            <i class="bi bi-x-lg text-muted"></i>
                                        </a>
                                    }
                                    <button type="submit" class="btn btn-primary px-4 fw-bold">Tìm</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-semibold" style="width: 35%;">NGƯỜI DÙNG</th>
                                    <th class="text-muted fw-semibold">TRẠNG THÁI</th>
                                    <th class="text-muted fw-semibold">VI PHẠM</th>
                                    <th class="text-muted fw-semibold text-center">ĐIỂM</th>
                                    <th class="text-end pe-4 text-muted fw-semibold">THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any()) {
                                    foreach (var user in Model) {
                                        // Logic xác định trạng thái khóa: Bị khóa thủ công HOẶC vi phạm >= 3 lần
                                        bool isEffectivelyBanned = user.IsBanned || user.WarningCount >= 3;

                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="position-relative">
                                                        <img src="@(string.IsNullOrEmpty(user.Avatar) ? "/images/default-avatar.png" : user.Avatar)" 
                                                             class="rounded-circle shadow-sm border" width="48" height="48" style="object-fit: cover;">
                                                        @if (!isEffectivelyBanned) {
                                                            <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle" title="Online"></span>
                                                        }
                                                    </div>
                                                    <div class="ms-3">
                                                        <div class="fw-bold text-dark">@user.FullName</div>
                                                        <div class="text-muted small">@user.Email</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (isEffectivelyBanned) {
                                                    <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-2">
                                                        <i class="bi bi-lock-fill me-1"></i> Bị khóa
                                                    </span>
                                                } else {
                                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2">
                                                        <i class="bi bi-check-circle-fill me-1"></i> Hoạt động
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="progress flex-grow-1 me-2" style="height: 6px; width: 60px;">
                                                        <div class="progress-bar @(user.WarningCount >= 2 ? "bg-danger" : "bg-warning")" 
                                                             style="width: @(user.WarningCount * 33.33)%"></div>
                                                    </div>
                                                    <span class="fw-bold text-dark">@user.WarningCount/3</span>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info-subtle text-info border border-info rounded-pill px-3">
                                                    @user.Points.ToString("N0") <i class="bi bi-coin ms-1"></i>
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group shadow-sm rounded-3 overflow-hidden border">
                                                    <form asp-area="Admin" asp-controller="User" asp-action="ToggleBan" asp-route-id="@user.Id" method="post" class="d-inline" 
                                                          onsubmit="return confirm('Bạn có chắc muốn @(isEffectivelyBanned ? "Mở khóa" : "Khóa") tài khoản này?');">
                                                        <button type="submit" class="btn btn-white border-0 py-2 px-3 @(isEffectivelyBanned ? "text-success" : "text-danger")" 
                                                                title="@(isEffectivelyBanned ? "Mở khóa tài khoản" : "Khóa tài khoản")">
                                                            <i class="bi @(isEffectivelyBanned ? "bi-unlock-fill" : "bi-lock-fill")"></i>
                                                        </button>
                                                    </form>
                                                    
                                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-white border-0 py-2 px-3 text-primary border-start" title="Xem chi tiết">
                                                        <i class="bi bi-eye-fill"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="bi bi-person-x display-4 text-muted opacity-25"></i>
                                            <p class="text-muted mt-3 mb-0">Không tìm thấy người dùng nào khớp với yêu cầu của bạn.</p>
                                            <a asp-action="Index" class="btn btn-link btn-sm mt-1">Xóa bộ lọc</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background-color: #fff; }
    .btn-white:hover { background-color: #f8f9fa; }
    .table-hover tbody tr:hover { background-color: rgba(13, 110, 253, 0.02); }
    .animate__animated { animation-duration: 0.5s; }
</style>