@model IEnumerable<StudyShare.ViewModels.UserViewModel>
@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject UserManager<AppUser> UserManager
@{ 
    ViewData["Title"] = "Quản trị người dùng";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container-fluid py-4" style="background-color: #f8f9fc; min-height: 100vh;">
    <div class="row g-4">
        
        <div class="col-xl-3 col-lg-4 d-none d-lg-block">
            <div class="sticky-top" style="top: 20px;">
                @await Html.PartialAsync("_AdminSidebarPartial")
            </div>
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
                <div class="card-header bg-white p-4 d-flex flex-column flex-xxl-row justify-content-between align-items-xxl-center border-bottom">
                    <h4 class="m-0 fw-bold text-primary mb-3 mb-xxl-0">
                        <i class="bi bi-people-fill me-2"></i>Tài khoản hệ thống
                    </h4>
                    
                    <form asp-action="Index" method="get" class="d-flex w-100" style="max-width: 450px;">
                        <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                            <input type="text" name="searchString" class="form-control border-0 px-4 bg-light" 
                                   placeholder="Tìm tên hoặc email người dùng..." value="@ViewData["CurrentFilter"]" />
                            <button class="btn btn-primary px-4" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr class="text-nowrap">
                                <th class="ps-4 py-3 text-muted text-uppercase small fw-bold">Thành viên</th>
                                <th class="py-3 text-muted text-uppercase small fw-bold text-center">Quyền hạn</th>
                                <th class="py-3 text-muted text-uppercase small fw-bold text-center">Điểm số</th>
                                <th class="py-3 text-muted text-uppercase small fw-bold text-center">Vi phạm</th>
                                <th class="py-3 text-muted text-uppercase small fw-bold text-center">Trạng thái</th>
                                <th class="text-end pe-4 py-3 text-muted text-uppercase small fw-bold">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model) {
                                bool isMe = user.Id == currentUserId;
                                bool isSuperAdmin = user.Role == "SuperAdmin";
                                bool isAdmin = user.Role == "Admin";
                                bool isBanned = user.IsBanned || user.WarningCount >= 3;
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <img src="@(string.IsNullOrEmpty(user.Avatar) ? "/images/default-avatar.png" : user.Avatar)" 
                                                 class="rounded-circle shadow-sm object-fit-cover me-3 border border-2 border-white" width="45" height="45">
                                            <div class="text-nowrap">
                                                <div class="fw-bold text-dark fs-6">@user.FullName</div>
                                                <small class="text-muted">@user.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (isSuperAdmin) {
                                            <span class="badge bg-dark rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-star-fill text-warning me-1"></i> Super</span>
                                        } else if (isAdmin) {
                                            <span class="badge bg-info-subtle text-info border border-info rounded-pill px-3 py-2">Admin</span>
                                        } else {
                                            <span class="badge bg-light text-secondary border rounded-pill px-3 py-2">User</span>
                                        }
                                    </td>
                                    <td class="text-center fw-bold text-primary">
                                        <i class="bi bi-coin me-1"></i>@user.Points
                                    </td>
                                    <td class="text-center">
                                        @if (user.WarningCount > 0) {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-2">
                                                @user.WarningCount gậy
                                            </span>
                                        } else {
                                            <span class="text-muted small">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (isBanned) {
                                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-lock-fill me-1"></i> Khóa</span>
                                        } else {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> OK</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-1">
                                            @if (User.IsInRole("SuperAdmin") && !isSuperAdmin && !isMe) {
                                                <div class="dropdown">
                                                    <button class="btn btn-sm btn-light border rounded-pill px-2 shadow-sm" data-bs-toggle="dropdown">
                                                        <i class="bi bi-gear-fill text-dark small"></i>
                                                    </button>
                                                    <ul class="dropdown-menu shadow border-0 rounded-3">
                                                        @if (!isAdmin) {
                                                            <li><form asp-action="ChangeRole" asp-route-userId="@user.Id" asp-route-role="Admin" method="post"><button class="dropdown-item fw-medium text-primary"><i class="bi bi-arrow-up-circle me-2"></i> Lên Admin</button></form></li>
                                                        } else {
                                                            <li><form asp-action="ChangeRole" asp-route-userId="@user.Id" asp-route-role="User" method="post"><button class="dropdown-item fw-medium text-danger"><i class="bi bi-arrow-down-circle me-2"></i> Hạ xuống User</button></form></li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                            @if (!isSuperAdmin && !isMe) {
                                                <form asp-action="ToggleBan" asp-route-id="@user.Id" method="post" class="m-0">
                                                    <button class="btn btn-sm @(isBanned ? "btn-success" : "btn-outline-danger") rounded-pill px-2 shadow-sm" title="@(isBanned ? "Mở khóa" : "Khóa")">
                                                        <i class="bi @(isBanned ? "bi-unlock-fill" : "bi-lock-fill") small"></i>
                                                    </button>
                                                </form>
                                            }
                                            <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-primary rounded-pill px-2 shadow-sm" title="Xem hồ sơ">
                                                <i class="bi bi-eye-fill small"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>