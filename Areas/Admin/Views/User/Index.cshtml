@model IEnumerable<StudyShare.Models.AppUser>

<h2>Quản lý người dùng</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    @if (user.IsBanned) { <span class="badge bg-danger">Bị khóa</span> }
                    else { <span class="badge bg-success">Hoạt động</span> }
                </td>
                <td>
                    @if (!user.IsBanned)
                    {
                        <form asp-action="BanUser" asp-route-id="@user.Id" method="post" style="display:inline">
                            <button class="btn btn-warning btn-sm">Khóa</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="UnbanUser" asp-route-id="@user.Id" method="post" style="display:inline">
                            <button class="btn btn-primary btn-sm">Mở khóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>