@model IEnumerable<StudyShare.ViewModels.UserViewModel>
@{ 
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold text-primary">Danh sách người dùng</h5>
        <form asp-area="Admin" asp-controller="User" asp-action="Index" method="get" class="d-flex w-50">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" 
                       placeholder="Tìm theo tên hoặc email..." 
                       value="@ViewData["CurrentFilter"]" />
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
                }
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Email</th>
                        <th>Điểm tích lũy</th>
                        <th>Cảnh cáo</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model) {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@(user.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-2" width="40" height="40" style="object-fit: cover;">
                                <span class="fw-bold">@user.FullName</span>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-primary">@user.Points đ</span></td>
                        <td><span class="badge bg-warning text-dark">@user.WarningCount lần</span></td>
                        <td>
                            @if (user.IsBanned) {
                                <span class="badge bg-danger">Bị khóa</span>
                            } else {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-area="Admin" asp-controller="User" asp-action="ToggleBan" asp-route-id="@user.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm @(user.IsBanned ? "btn-warning" : "btn-outline-danger")" title="Khóa/Mở khóa">
                                    <i class="bi @(user.IsBanned ? "bi-unlock" : "bi-lock")"></i>
                                </button>
                            </form>

                            @* Thêm nút Sửa cho Admin tại đây *@
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning mx-1" title="Sửa thông tin">
                                <i class="bi bi-pencil-fill"></i>
                            </a>

                            <a asp-area="Admin" asp-controller="User" asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info text-white" title="Xem chi tiết">
                                <i class="bi bi-info-circle"></i> Chi tiết
                            </a>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>