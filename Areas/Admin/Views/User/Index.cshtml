@model IEnumerable<StudyShare.Models.AppUser>
@{ 
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <h5 class="m-0 fw-bold text-primary">Danh sách người dùng</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Email</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model) {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@(user.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-2" width="40" height="40" style="object-fit: cover;">
                                <span class="fw-bold">@user.FullName</span>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
    @if (user.IsBanned) {
        <span class="badge bg-danger">Bị khóa vi phạm</span>
    } else {
        <span class="badge bg-success">Hoạt động</span>
    }
</td>
                        <td class="text-end">
    <form asp-area="Admin" asp-controller="User" asp-action="ToggleBan" asp-route-id="@user.Id" method="post" class="d-inline">
        <button type="submit" class="btn btn-sm @(user.IsBanned ? "btn-warning" : "btn-outline-danger")">
            <i class="bi @(user.IsBanned ? "bi-unlock" : "bi-lock")"></i>
        </button>
    </form>
    <a asp-area="Admin" asp-controller="User" asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
</td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>