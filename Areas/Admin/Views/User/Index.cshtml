@model IEnumerable<StudyShare.Models.AppUser>
<div class="card shadow-sm p-4">
    <h3 class="fw-bold mb-4">Quản lý thành viên</h3>
    <table class="table table-hover">
        <thead><tr><th>Avatar</th><th>Họ tên</th><th>Email</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
        <tbody>
            @foreach(var user in Model){
                <tr>
                    <td><img src="@(user.Avatar ?? "/images/default-avatar.png")" width="35" height="35" class="rounded-circle"></td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @if(user.LockoutEnd > DateTime.Now){ <span class="badge bg-danger">Đã khóa</span> }
                        else { <span class="badge bg-success">Hoạt động</span> }
                    </td>
                    <td>
                        <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post">
                            <button class="btn btn-sm @(user.LockoutEnd > DateTime.Now ? "btn-warning" : "btn-outline-danger")">
                                @(user.LockoutEnd > DateTime.Now ? "Mở khóa" : "Khóa")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>