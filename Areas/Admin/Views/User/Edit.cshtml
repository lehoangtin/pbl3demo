@model StudyShare.DTOs.Responses.UserResponse
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách</a>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white p-4 border-bottom">
                    <h4 class="m-0 fw-bold text-warning"><i class="bi bi-person-gear me-2"></i>Chỉnh sửa tài khoản</h4>
                </div>
                <div class="card-body p-4 p-md-5 bg-light">
                    <form asp-area="Admin" asp-controller="User" asp-action="Edit" method="post" class="bg-white p-4 rounded-4 shadow-sm border">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Email đăng nhập</label>
                            <input type="text" class="form-control form-control-lg bg-light text-muted" value="@Model.Email" readonly disabled />
                        </div>

                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label fw-bold text-dark">Họ và Tên</label>
                            <input asp-for="FullName" class="form-control form-control-lg rounded-3" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label asp-for="Points" class="form-label fw-bold text-primary"><i class="bi bi-coin me-1"></i> Điểm tích lũy</label>
                                <input asp-for="Points" type="number" class="form-control form-control-lg rounded-3" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="WarningCount" class="form-label fw-bold text-warning"><i class="bi bi-exclamation-triangle-fill me-1"></i> Số lần cảnh cáo</label>
                                <input asp-for="WarningCount" type="number" class="form-control form-control-lg rounded-3" />
                            </div>
                        </div>

                        <div class="mb-5 p-3 bg-danger-subtle rounded-3 border border-danger border-opacity-25">
                            <div class="form-check form-switch fs-5">
                                <input asp-for="IsBanned" class="form-check-input" type="checkbox" id="isBannedSwitch">
                                <label class="form-check-label fw-bold text-danger ms-2" for="isBannedSwitch">Khóa tài khoản (Ban)</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 rounded-pill shadow-sm">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 rounded-pill text-dark fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>