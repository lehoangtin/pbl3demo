@model StudyShare.Models.AppUser

@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white py-3">
                <h5 class="m-0 fw-bold text-primary"><i class="bi bi-person-lines-fill"></i> Chỉnh sửa thông tin người dùng</h5>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="User" asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="text" class="form-control bg-light" value="@Model.Email" readonly disabled />
                        <small class="text-muted">Email là định danh đăng nhập nên không thể thay đổi tại đây.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-bold">Họ và Tên</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Points" class="form-label fw-bold text-primary">Điểm tích lũy</label>
                            <input asp-for="Points" type="number" class="form-control" />
                            <span asp-validation-for="Points" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WarningCount" class="form-label fw-bold text-warning">Số lần cảnh cáo</label>
                            <input asp-for="WarningCount" type="number" class="form-control" />
                            <span asp-validation-for="WarningCount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4 form-check form-switch fs-5">
                        <input asp-for="IsBanned" class="form-check-input" type="checkbox" id="isBannedSwitch">
                        <label class="form-check-label fw-bold text-danger" for="isBannedSwitch">Khóa tài khoản (Ban)</label>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left"></i> Trở về
                        </a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}