@model StudyShare.DTOs.Requests.QuestionUpdateRequest
@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 fw-bold text-primary">Chỉnh sửa nội dung câu hỏi</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-bold">Nội dung thắc mắc</label>
                            <textarea asp-for="Content" class="form-control" rows="6" 
                                      placeholder="Hãy nhập nội dung chi tiết câu hỏi của bạn..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light border">Quay lại</a>
                            <button type="submit" class="btn btn-success px-4">Cập nhật câu hỏi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <!-- 🔥 SweetAlert hiển thị lỗi AI -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @if (ViewBag.Error != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Nội dung vi phạm!',
                    text: '@Html.Raw(ViewBag.Error)',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Đã hiểu'
                });
                </text>
            }
        });
    </script>
}