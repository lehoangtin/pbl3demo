@model StudyShare.DTOs.Requests.QuestionCreateRequest
@{ ViewData["Title"] = "Đặt câu hỏi thảo luận"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-patch-question-fill me-2"></i> Đặt câu hỏi mới</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-bold">Nội dung câu hỏi <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" class="form-control rounded-3" rows="6" placeholder="Mô tả chi tiết vấn đề bạn đang thắc mắc..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold flex-grow-1 shadow-sm">Đăng câu hỏi</button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 border">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>