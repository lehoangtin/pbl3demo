@model StudyShare.DTOs.Requests.QuestionCreateRequest
@{
    ViewData["Title"] = "Đặt câu hỏi mới";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h4 class="fw-bold text-dark mb-4"><i class="bi bi-patch-question text-primary me-2"></i> Đặt câu hỏi thảo luận</h4>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-bold text-secondary">Nội dung câu hỏi của bạn</label>
                            <textarea asp-for="Content" class="form-control rounded-3" rows="6" placeholder="Mô tả chi tiết thắc mắc của bạn vào đây..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-end align-items-center">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 me-3 fw-medium">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                                <i class="bi bi-send me-1"></i> Đăng câu hỏi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}