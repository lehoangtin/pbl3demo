@model StudyShare.Models.Question
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4 rounded-4">
                <div class="card-body p-4 border-bottom">
                    <div class="d-flex align-items-center mb-3">
                        <img src="@(Model.User?.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-2" width="30" height="30">
                        <span class="fw-bold">@Model.User?.FullName</span>
                        <small class="text-muted ms-auto">@Model.CreatedAt.ToString("g")</small>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.Content</h4>
                </div>

                <div class="card-body bg-light p-4">
                    <h6 class="fw-bold mb-4">Các phản hồi (@Model.Answers?.Count())</h6>
                    @foreach (var ans in Model.Answers.OrderBy(a => a.CreatedAt)) {
                        <div class="d-flex mb-4">
                            <img src="@(ans.User?.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-3" width="40" height="40">
                            <div class="bg-white p-3 rounded-4 shadow-sm flex-grow-1">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold">@ans.User?.FullName</span>
                                    <small class="text-muted small">@ans.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </div>
                                <p class="mb-0 small">@ans.Content</p>
                            </div>
                        </div>
                    }

                    @if (User.Identity.IsAuthenticated) {
                        <hr class="my-4">
                        <form asp-action="PostAnswer" method="post">
                            <input type="hidden" name="questionId" value="@Model.Id" />
                            <div class="form-group mb-2">
                                <textarea name="content" class="form-control rounded-4" rows="3" placeholder="Nhập câu trả lời của bạn..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4">Gửi phản hồi</button>
                        </form>
                    } else {
                        <div class="alert alert-warning small rounded-4">Vui lòng đăng nhập để tham gia thảo luận.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>