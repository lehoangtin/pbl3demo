@model StudyShare.Models.Question
<div class="container mt-4">
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h4 class="fw-bold">@Model.Content</h4>
        <small class="text-muted">Đăng bởi: @Model.User?.FullName | @Model.CreatedAt</small>
    </div>

    <h5 class="fw-bold mb-3">Câu trả lời (@Model.Answers.Count)</h5>
    @foreach (var a in Model.Answers.OrderBy(x => x.CreatedAt)) {
        <div class="card border-0 shadow-sm rounded-4 mb-2 p-3 bg-light">
            <div class="d-flex">
                <img src="@(a.User?.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-2" width="30" height="30">
                <div>
                    <div class="fw-bold">@a.User?.FullName</div>
                    <div>@a.Content</div>
                    <small class="text-muted">@a.CreatedAt</small>
                </div>
            </div>
        </div>
    }

    @if (User.Identity.IsAuthenticated) {
        <form asp-action="PostAnswer" method="post" class="mt-4">
            <input type="hidden" name="questionId" value="@Model.Id" />
            <textarea name="content" class="form-control rounded-4 mb-2" placeholder="Viết câu trả lời của bạn..."></textarea>
            <button type="submit" class="btn btn-success rounded-pill px-4">Gửi câu trả lời</button>
        </form>
    }
</div>