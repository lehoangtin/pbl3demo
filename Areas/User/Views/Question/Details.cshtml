@model StudyShare.Models.Question
@{
    ViewData["Title"] = "Chi tiết câu hỏi";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-link text-decoration-none p-0">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách thảo luận
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center mb-3">
            <img src="@(Model.User?.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-3" width="45" height="45">
            <div>
                <h6 class="fw-bold mb-0">@Model.User?.FullName</h6>
                <small class="text-muted">Đã đăng vào: @Model.CreatedAt.ToString("HH:mm dd/MM/yyyy")</small>
            </div>
        </div>
        <h4 class="fw-bold text-dark">@Model.Content</h4>
    </div>

    <h5 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2"></i>Câu trả lời (@Model.Answers.Count)</h5>
    
    @if (Model.Answers.Any()) {
        @foreach (var a in Model.Answers.OrderBy(x => x.CreatedAt)) {
            <div class="card border-0 shadow-sm rounded-4 mb-3 p-3 bg-light border-start border-primary border-4">
                <div class="d-flex">
                    <img src="@(a.User?.Avatar ?? "/images/default-avatar.png")" class="rounded-circle me-3" width="35" height="35">
                    <div>
                        <div class="fw-bold text-primary">@a.User?.FullName</div>
                        <div class="my-1">@a.Content</div>
                        <small class="text-muted">@a.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                </div>
            </div>
        }
    } else {
        <div class="alert alert-light border shadow-sm rounded-4">
            Chưa có câu trả lời nào cho vấn đề này.
        </div>
    }

    @if (User.Identity.IsAuthenticated) {
        <div class="card border-0 shadow-sm rounded-4 p-3 mt-4">
            <h6 class="fw-bold mb-3">Gửi câu trả lời của bạn</h6>
            <form asp-area="User" asp-controller="Question" asp-action="PostAnswer" method="post">
                <input type="hidden" name="questionId" value="@Model.Id" />
                <textarea name="content" required class="form-control rounded-4 mb-3" rows="3" placeholder="Chia sẻ kiến thức của bạn tại đây..."></textarea>
                <div class="text-end">
                    <button type="submit" class="btn btn-success rounded-pill px-4 py-2">
                        <i class="bi bi-send-fill me-2"></i>Gửi câu trả lời
                    </button>
                </div>
            </form>
        </div>
    } else {
        <div class="alert alert-warning rounded-4 mt-4">
            Vui lòng <a asp-area="" asp-controller="Account" asp-action="Login">đăng nhập</a> để tham gia thảo luận.
        </div>
    }
</div>