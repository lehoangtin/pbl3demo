@model StudyShare.Models.Question
<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h2 class="fw-bold">@Model.Content</h2> <p class="text-muted">Đăng bởi: @Model.User?.FullName</p>
        </div>
    </div>

    <h4>Thảo luận (@Model.Answers.Count)</h4>
@foreach (var answer in Model.Answers) {
    <div class="mb-3 p-3 bg-light rounded shadow-sm">
        <div class="d-flex justify-content-between">
            <strong>@answer.User.FullName</strong>
            
            <form asp-action="Report" method="post" class="d-inline">
                <input type="hidden" name="answerId" value="@answer.Id" />
                <div class="input-group input-group-sm">
                    <select name="reason" class="form-select form-select-sm border-0 bg-transparent text-danger small" style="width: 100px;">
                        <option value="Spam">Spam</option>
                        <option value="Toxic">Toxic</option>
                        <option value="Wrong">Sai kiến thức</option>
                    </select>
                    <button type="submit" class="btn btn-sm text-danger"><i class="bi bi-flag"></i></button>
                </div>
            </form>
        </div>
        <p class="mb-0">@answer.Content</p>
    </div>
}

    <form asp-action="PostAnswer" method="post" class="mt-4">
        <input type="hidden" name="questionId" value="@Model.Id" /> <textarea name="content" class="form-control mb-2" placeholder="Trả lời câu hỏi này..."></textarea>
        <button type="submit" class="btn btn-primary">Gửi câu trả lời</button>
    </form>
    <button class="btn btn-sm btn-link text-danger" data-bs-toggle="modal" data-bs-target="#reportQuestionModal">
    <i class="bi bi-flag"></i> Báo cáo vi phạm
</button>

<div class="modal fade" id="reportQuestionModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Report" method="post">
            <input type="hidden" name="questionId" value="@Model.Id" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Báo cáo vi phạm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Lý do báo cáo:</label>
                    <select name="reason" class="form-select" required>
                        <option value="Spam">Nội dung rác (Spam)</option>
                        <option value="Toxic">Ngôn từ không phù hợp</option>
                        <option value="WrongContent">Nội dung sai kiến thức</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Gửi báo cáo</button>
                </div>
            </div>
        </form>
    </div>
</div>
</div>