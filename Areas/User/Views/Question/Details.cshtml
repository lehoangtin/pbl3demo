@model StudyShare.ViewModels.QuestionViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Chi tiết thảo luận";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3 d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại diễn đàn
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden border-start border-primary border-4">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary-subtle text-primary rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 text-dark">@Model.AuthorName</h6>
                                <small class="text-muted"><i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        
                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#reportQuestionModal">
                            <i class="bi bi-flag-fill me-1"></i> Báo cáo
                        </button>
                    </div>
                    
                    <h4 class="fw-bold text-dark lh-base" style="white-space: pre-wrap;">@Model.Content</h4>
                    
                    @if (User.Identity?.IsAuthenticated == true && Model.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                    {
                        <div class="mt-4 pt-3 border-top text-end">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa câu hỏi này cùng tất cả câu trả lời?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-chat-dots-fill text-info me-2"></i> Thảo luận (@(Model.Answers != null ? Model.Answers.Count() : 0))</h5>

            @if (Model.Answers != null && Model.Answers.Any())
            {
                <div class="row g-3 mb-4">
                    @foreach (var answer in Model.Answers)
                    {
                        <div class="col-12">
                            <div class="card border-0 shadow-sm rounded-4 bg-light">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between mb-2">
                                        <div>
                                            <strong class="text-primary me-2">@(answer.AuthorName ?? "Ẩn danh")</strong>
                                            <small class="text-muted">@answer.CreatedAt.ToString("HH:mm dd/MM/yyyy")</small>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <form asp-action="Report" method="post" class="d-inline">
                                                <input type="hidden" name="answerId" value="@answer.Id" />
                                                <div class="input-group input-group-sm bg-white rounded-pill overflow-hidden border shadow-sm">
                                                    <select name="reason" class="form-select form-select-sm border-0 text-danger small ps-3" style="width: 110px;" required>
                                                        <option value="" disabled selected>Báo cáo...</option>
                                                        <option value="Spam">Spam</option>
                                                        <option value="Toxic">Toxic</option>
                                                        <option value="Wrong">Sai kiến thức</option>
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-light text-danger pe-3" title="Gửi báo cáo">
                                                        <i class="bi bi-flag"></i>
                                                    </button>
                                                </div>
                                            </form>

                                            @if (User.Identity?.IsAuthenticated == true && answer.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                                            {
                                               <form asp-controller="Question" asp-action="DeleteAnswer" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa câu trả lời này?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="answerId" value="@answer.Id" />
                                                    <input type="hidden" name="questionId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                    <p class="mb-0 text-dark fs-6" style="white-space: pre-wrap;">@answer.Content</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 bg-white border border-primary border-opacity-25 rounded-4">
                    <form asp-action="PostAnswer" method="post">
                        <input type="hidden" name="questionId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-reply-fill text-primary"></i> Câu trả lời của bạn</label>
                            <textarea name="content" class="form-control rounded-3 bg-light border-0 shadow-sm" rows="3" placeholder="Chia sẻ ý kiến hoặc giải pháp của bạn..." required></textarea>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi bi-send-fill me-1"></i> Gửi câu trả lời
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="reportQuestionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="Report" method="post">
            <input type="hidden" name="questionId" value="@Model.Id" />
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Báo cáo vi phạm</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <label class="form-label fw-bold">Lý do báo cáo:</label>
                    <select name="reason" class="form-select form-select-lg rounded-3 bg-light shadow-sm border-0" required>
                        <option value="">-- Chọn lý do --</option>
                        <option value="Spam">Nội dung rác (Spam / Quảng cáo)</option>
                        <option value="Toxic">Ngôn từ không phù hợp / Xúc phạm</option>
                        <option value="WrongContent">Nội dung sai kiến thức nghiêm trọng</option>
                    </select>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Gửi báo cáo</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 🔴 ERROR
            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Cảnh báo!',
                    text: '@Html.Raw(TempData["Error"])',
                    confirmButtonColor: '#d33',
                    borderRadius: '15px'
                });
                </text>
            }

            // 🟢 SUCCESS
            @if (TempData["Message"] != null || TempData["Success"] != null)
            {
                var msg = TempData["Message"] ?? TempData["Success"];
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(msg)',
                    confirmButtonColor: '#0d6efd',
                    borderRadius: '15px'
                });
                </text>
            }
        });
    </script>
}