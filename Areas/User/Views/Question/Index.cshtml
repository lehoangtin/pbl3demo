@model IEnumerable<StudyShare.ViewModels.QuestionViewModel>
@{ 
    ViewData["Title"] = "Thảo luận cộng đồng";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-12">
            <div class="row align-items-center mb-4">
                <div class="col-md-3 mb-3 mb-md-0">
                    <h3 class="fw-bold text-dark m-0"><i class="bi bi-people-fill text-primary me-2"></i> Thảo luận</h3>
                </div>
                
                <div class="col-md-6 mb-3 mb-md-0">
                    <form asp-action="Index" method="get">
                        <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                            <span class="input-group-text bg-white border-0 ps-3">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="searchString" class="form-control border-0 bg-white py-2" 
                                   placeholder="Tìm kiếm nội dung, tác giả..." value="@ViewData["CurrentFilter"]" />
                            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                            {
                                <a asp-action="Index" class="btn btn-white border-0 d-flex align-items-center px-3 text-muted" title="Xóa tìm kiếm">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            }
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Tìm</button>
                        </div>
                    </form>
                </div>

                <div class="col-md-3 text-md-end">
                    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold w-100">
                        <i class="bi bi-plus-circle-fill me-1"></i> Đặt câu hỏi
                    </a>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center p-5 bg-light rounded-4 border border-dashed text-muted">
                    <i class="bi bi-chat-square-dots display-4 opacity-50 d-block mb-3"></i>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <h4>Không tìm thấy kết quả nào</h4>
                        <p>Không có câu hỏi nào khớp với từ khóa "@ViewData["CurrentFilter"]". <a asp-action="Index" class="text-decoration-none">Nhấn vào đây để xem tất cả.</a></p>
                    }
                    else
                    {
                        <h4>Chưa có chủ đề thảo luận nào</h4>
                        <p>Hãy là người đầu tiên bấm vào nút "Đặt câu hỏi" để bắt đầu.</p>
                    }
                </div>
            }

            <div class="row g-3">
                @foreach (var q in Model)
                {
                    <div class="col-12">
                        <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden transition-hover">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start">
                                    <div class="text-center me-4 bg-primary-subtle text-primary p-3 rounded-4 d-flex flex-column justify-content-center" style="min-width: 90px; height: 90px;">
                                        <h3 class="mb-0 fw-bold">@q.AnswerCount</h3>
                                        <small class="fw-semibold" style="font-size: 0.8rem;">Trả lời</small>
                                    </div>
                                    
                                    <div class="flex-grow-1">
                                        <p class="text-muted small mb-2 d-flex align-items-center">
                                            <i class="bi bi-person-circle me-1"></i> <strong class="me-3 text-dark">@q.AuthorName</strong> 
                                            <i class="bi bi-clock me-1"></i> @q.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </p>
                                        <h5 class="fw-bold mb-0 lh-base">
                                            <a asp-action="Details" asp-route-id="@q.Id" class="text-decoration-none text-dark stretched-link">
                                                @(q.Content.Length > 200 ? q.Content.Substring(0, 200) + "..." : q.Content)
                                            </a>
                                        </h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transition: all 0.3s ease;
    }
</style>