@model IEnumerable<StudyShare.ViewModels.QuestionViewModel>
@{
    ViewData["Title"] = "Cộng đồng hỏi đáp";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Thảo luận & Hỏi đáp</h2>
                    <p class="text-muted mb-0">Nơi kết nối và chia sẻ kiến thức cùng cộng đồng</p>
                </div>
                
                <div class="d-flex gap-2">
                    <form asp-action="Index" method="get" class="d-flex">
                        <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                                   class="form-control border-0 px-3" placeholder="Tìm câu hỏi..." style="width: 250px;">
                            <button class="btn btn-white border-0 text-primary" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                        <i class="bi bi-plus-lg me-1"></i> Đặt câu hỏi
                    </a>
                </div>
            </div>

            <hr class="mb-4 opacity-10">

            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-12 col-lg-6">
                            <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift transition-all">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3">
                                            @(string.IsNullOrEmpty(item.CategoryName) ? "Chung" : item.CategoryName)
                                        </span>
                                        <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    
                                    <h5 class="card-title fw-bold text-dark mb-3">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark hover-primary">
                                            @(string.IsNullOrEmpty(item.Title) 
                                                ? (item.Content != null && item.Content.Length > 60 ? item.Content.Substring(0, 60) + "..." : item.Content) 
                                                : item.Title)
                                        </a>
                                    </h5>
                                    
                                    <p class="card-text text-muted text-truncate-2 mb-4" style="height: 3rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                        @item.Content
                                    </p>

                                    <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-2">
                                                <img src="/images/default-avatar.png" class="rounded-circle" width="30" height="30" alt="Avatar">
                                            </div>
                                            <span class="small fw-medium">@item.AuthorName</span>
                                        </div>
                                        <div class="text-primary small fw-bold">
                                            <i class="bi bi-chat-left-text me-1"></i> @item.AnswerCount Trả lời
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-muted opacity-25"></i>
                    <h4 class="mt-3 text-muted">Không tìm thấy câu hỏi nào phù hợp</h4>
                    <a asp-action="Index" class="btn btn-link text-decoration-none">Xóa bộ lọc tìm kiếm</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important; }
    .transition-all { transition: all 0.3s ease; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .hover-primary:hover { color: #0d6efd !important; }
    .btn-white { background: white; }
</style>