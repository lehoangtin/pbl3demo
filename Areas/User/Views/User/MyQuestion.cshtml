@model IEnumerable<StudyShare.Models.Question>
<h4 class="fw-bold mb-4">Các thảo luận của bạn</h4>
@foreach(var q in Model) {
    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
            <h6 class="fw-bold">@q.Content</h6>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">@q.CreatedAt.ToString("g")</small>
                <span class="badge bg-secondary">@q.Answers.Count() câu trả lời</span>
            </div>
        </div>
    </div>
}