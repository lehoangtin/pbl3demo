@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{
    ViewData["Title"] = "Tài liệu của tôi";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_UserSidebarPartial", (object)ViewBag.CurrentUser)
        </div>

        <div class="col-md-9">
            <h3 class="fw-bold mb-4 text-dark border-bottom pb-2">
                <i class="bi bi-folder-fill text-primary me-2"></i>Tài liệu đã đăng
            </h3>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="row g-4">
                @if (!Model.Any())
                {
                    <div class="col-12 text-center text-muted py-5 bg-light rounded-4 border border-dashed">
                        <i class="bi bi-folder-x display-1 text-secondary opacity-50"></i>
                        <p class="mt-3 fs-5">Bạn chưa chia sẻ tài liệu nào.</p>
                        <a asp-area="User" asp-controller="Document" asp-action="Create" class="btn btn-primary rounded-pill px-4 mt-2 shadow-sm">
                            <i class="bi bi-upload me-1"></i> Đăng tài liệu ngay
                        </a>
                    </div>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <div class="col-md-6 mb-2">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                                <div class="card-body p-4">
                                    <span class="badge bg-primary mb-2 px-2 py-1 shadow-sm">@item.CategoryName</span>
                                    <h5 class="card-title fw-bold text-truncate" title="@item.Title">@item.Title</h5>
                                    
                                    <div class="text-muted small mb-3">
                                        <div class="mb-1"><i class="bi bi-calendar-event me-1"></i> @item.UploadDate.ToString("dd/MM/yyyy HH:mm")</div>
                                        @* Hiển thị lượt tải nếu bạn đã thêm thuộc tính này vào ViewModel *@
                                        <div><i class="bi bi-download me-1"></i> @item.DownloadCount lượt tải</div>
                                    </div>

                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-2 py-1"><i class="bi bi-check-circle me-1"></i> Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning px-2 py-1"><i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt</span>
                                    }
                                </div>
                                <div class="card-footer bg-light border-top-0 p-3 d-flex gap-2 align-items-center">
                                    <a asp-area="User" asp-controller="Document" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm rounded-pill text-white fw-bold flex-grow-1 shadow-sm">
                                        <i class="bi bi-eye me-1"></i> Xem chi tiết
                                    </a>
                                    
                                    <form asp-area="User" asp-controller="User" asp-action="DeleteDocument" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa vĩnh viễn tài liệu này? Hành động này không thể hoàn tác.');">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle shadow-sm" style="width: 35px; height: 35px;" title="Xóa tài liệu">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>