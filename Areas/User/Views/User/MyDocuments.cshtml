@model IEnumerable<StudyShare.Models.Document>
<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">@await Html.PartialAsync("_UserSidebarPartial", (AppUser)ViewBag.User)</div>
        <div class="col-md-9">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <div class="d-flex justify-content-between mb-4">
                    <h4 class="fw-bold">Kho tài liệu của bạn</h4>
                    <a asp-controller="Document" asp-action="Create" class="btn btn-sm btn-primary">+ Tải lên</a>
                </div>
                <table class="table table-hover align-middle">
                    <thead><tr><th>Tên file</th><th>Ngày đăng</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
                    <tbody>
                        @foreach(var doc in Model) {
                            <tr>
                                <td><div class="fw-bold text-truncate" style="max-width: 300px;">@doc.Title</div></td>
                                <td>@doc.UploadDate.ToString("d")</td>
                                <td>
                                    @if(doc.IsApproved) { <span class="badge bg-success-subtle text-success border border-success">Đã duyệt</span> }
                                    else { <span class="badge bg-warning-subtle text-warning border border-warning">Đang chờ</span> }
                                </td>
                                <td>
                                    <form asp-action="DeleteDocument" asp-route-id="@doc.Id" method="post" onsubmit="return confirm('Bạn muốn xóa?')">
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>