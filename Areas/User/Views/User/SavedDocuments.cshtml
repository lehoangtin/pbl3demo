@model IEnumerable<StudyShare.Models.SavedDocument>
@{ 
    ViewData["Title"] = "Tài liệu đã lưu"; 
    // 🔥 Lấy User từ ViewBag đã được ép kiểu
    var userObject = ViewBag.CurrentUser as StudyShare.Models.AppUser;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            @* ✅ Truyền userObject vào tham số thứ 2 để Sidebar nhận đúng Model *@
            @if (userObject != null)
            {
                @await Html.PartialAsync("_UserSidebarPartial", userObject)
            }
        </div>
        <div class="col-md-9">
            <h4 class="fw-bold mb-4">Tài liệu bạn đã lưu</h4>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row g-4">
                @foreach (var item in Model) {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Document?.Title</h5>
                            <p class="text-muted small mb-3">Người đăng: @item.Document?.User?.FullName</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">Lưu ngày: @item.SavedDate.ToString("dd/MM/yyyy")</span>
                                <div class="btn-group">
                                    <a href="/Home/ViewDocument/@item.DocumentId" class="btn btn-sm btn-primary rounded-pill px-3">Xem ngay</a>
                                    
                                    @* Nút bỏ lưu *@
                                    <form asp-action="UnsaveDocument" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="docId" value="@item.DocumentId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Bỏ lưu</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
            
            @if (!Model.Any()) {
                <div class="text-center py-5">
                    <i class="bi bi-bookmark-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Bạn chưa lưu tài liệu nào.</p>
                </div>
            }
        </div>
    </div>
</div>