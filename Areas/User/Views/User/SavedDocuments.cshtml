@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{ 
    ViewData["Title"] = "Tài liệu đã lưu"; 
    var userObject = ViewBag.CurrentUser;
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_UserSidebarPartial", (object)userObject)
        </div>
        <div class="col-md-9">
            <h3 class="fw-bold mb-4 text-dark border-bottom pb-2">
                <i class="bi bi-bookmark-heart text-danger me-2"></i>Tài liệu bạn đã lưu
            </h3>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any()) {
                <div class="text-center py-5 bg-light rounded-4 border">
                    <i class="bi bi-bookmark-x text-muted display-1"></i>
                    <p class="text-muted mt-3 fs-5">Bạn chưa lưu tài liệu nào.</p>
                    <a asp-area="" asp-controller="Document" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-2 shadow-sm">Khám phá tài liệu ngay</a>
                </div>
            } else {
                <div class="row g-4">
                    @foreach (var item in Model) {
                    <div class="col-md-6 mb-2">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                            <div class="card-body p-4">
                                <span class="badge bg-primary mb-2 shadow-sm">@item.CategoryName</span>
                                <h5 class="card-title fw-bold text-truncate" title="@item.Title">@item.Title</h5>
                                
                                <div class="text-muted small mb-3">
                                    <div class="mb-1"><i class="bi bi-person-circle me-1"></i> @item.AuthorName</div>
                                    <div><i class="bi bi-calendar-event me-1"></i> @item.UploadDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                            <div class="card-footer bg-light border-top-0 p-3 d-flex gap-2 align-items-center">
                                <a href="/Home/ViewDocument/@item.Id" class="btn btn-info btn-sm rounded-pill text-white fw-bold flex-grow-1 shadow-sm">
                                    <i class="bi bi-eye me-1"></i> Xem ngay
                                </a>
                                
                                <form asp-area="User" asp-controller="User" asp-action="UnsaveDocument" method="post" class="m-0">
                                    <input type="hidden" name="docId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle shadow-sm" style="width: 35px; height: 35px;" title="Bỏ lưu">
                                        <i class="bi bi-bookmark-x"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    }
                </div>
            }
        </div>
    </div>
</div>