@model StudyShare.Models.AppUser

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body text-center pt-5">
        <div class="mb-3">
            <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/default-avatar.png" : Model.Avatar)" 
                 class="rounded-circle img-thumbnail shadow-sm" style="width: 120px; height: 120px; object-fit: cover;" />
        </div>
        <h5 class="fw-bold mb-0">@Model.FullName</h5>
        <p class="text-muted small">@Model.Email</p>
    </div>
    <div class="list-group list-group-flush pb-3">
        <a asp-action="Profile" class="list-group-item list-group-item-action border-0 px-4 py-2">
            <i class="bi bi-person-circle me-2"></i> Tổng quan
        </a>
        <a asp-action="MyDocuments" class="list-group-item list-group-item-action border-0 px-4 py-2">
            <i class="bi bi-file-earmark-text me-2"></i> Tài liệu của tôi
        </a>
        <a asp-action="SavedDocuments" class="list-group-item list-group-item-action border-0 px-4 py-2">
            <i class="bi bi-bookmark-heart me-2"></i> Tài liệu đã lưu
        </a>
        <a asp-action="MyQuestions" class="list-group-item list-group-item-action border-0 px-4 py-2">
            <i class="bi bi-patch-question me-2"></i> Câu hỏi của tôi
        </a>
        <hr class="mx-4 my-2">
        <a asp-action="Edit" class="list-group-item list-group-item-action border-0 px-4 py-2 text-primary">
            <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa hồ sơ
        </a>
        <a asp-action="ChangePassword" class="list-group-item list-group-item-action border-0 px-4 py-2 text-danger">
            <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
        </a>
    </div>
</div>