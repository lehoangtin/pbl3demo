@model IEnumerable<StudyShare.ViewModels.ReportViewModel>
@{
    ViewData["Title"] = "Lịch sử vi phạm";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_UserSidebarPartial")
        </div>
        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-4 border-bottom">
                    <h4 class="m-0 fw-bold text-danger"><i class="bi bi-shield-lock-fill me-2"></i>Lịch sử vi phạm của bạn</h4>
                    <p class="text-muted small mb-0 mt-1">Lưu ý: Nếu vi phạm quá 3 lần, tài khoản sẽ bị khóa vĩnh viễn.</p>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-semibold">THỜI GIAN</th>
                                    <th class="text-muted fw-semibold">NỘI DUNG/LÝ DO</th>
                                    <th class="text-muted fw-semibold">HÌNH THỨC XỬ LÝ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any()) {
                                    foreach (var item in Model) {
                                        <tr>
                                            <td class="ps-4 py-3 fw-medium">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <div class="fw-bold text-dark">@item.Reason</div>
                                                @if (item.DocumentId != null) {
                                                    <small class="text-primary">Liên quan đến tài liệu ID: @item.DocumentId</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-danger-subtle text-danger px-3 py-2 border border-danger-subtle rounded-pill">
                                                    @item.ActionTaken
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <i class="bi bi-check-circle display-4 text-success opacity-50"></i>
                                            <p class="text-muted mt-3">Tài khoản của bạn rất trong sạch. Hãy tiếp tục duy trì nhé!</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>