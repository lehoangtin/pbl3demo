@model StudyShare.Models.AppUser
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_UserSidebarPartial", Model)
        </div>

        <div class="col-md-9">
            <div class="mb-3">
                <a asp-action="Profile" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại tổng quan
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-person-lines-fill text-primary me-2"></i>Cập nhật thông tin cá nhân</h4>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <form asp-area="User" asp-controller="User" asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Avatar" />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control form-control-lg rounded-3" placeholder="Nhập họ và tên..." />
                            <span asp-validation-for="FullName" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control form-control-lg rounded-3 bg-light" readonly />
                            <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle me-1"></i>Email không thể thay đổi để đảm bảo định danh.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg rounded-3" placeholder="Nhập số điện thoại..." />
                        </div>

                        <div class="mb-5 p-3 bg-light rounded-3 border">
                            <label class="form-label fw-bold"><i class="bi bi-image me-2"></i>Ảnh đại diện</label>
                            <input type="file" name="avatarFile" class="form-control" accept="image/*" />
                            <small class="text-muted mt-2 d-block">Chọn một tấm ảnh mới nếu bạn muốn thay đổi. Bỏ trống nếu muốn giữ nguyên ảnh cũ.</small>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-3 border-top">
                            <a asp-action="Profile" class="btn btn-light btn-lg px-4 rounded-pill shadow-sm">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill shadow-sm">
                                <i class="bi bi-save me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}