@model StudyShare.Models.AppUser

<h2>✏️ Chỉnh sửa Profile</h2>

<form asp-area="User" asp-controller="User" asp-action="Edit" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label>Full Name</label>
        <input asp-for="FullName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Avatar</label>
        <input type="file" name="avatarFile" class="form-control" />
    </div>

    <!-- preview avatar -->
    <div class="mb-3">
        <img src="@(Model.Avatar ?? "/images/default-avatar.png")"
             width="120" style="border-radius:50%;" />
    </div>

    <button class="btn btn-success">Lưu</button>

</form>