<div class="row">
    <div class="col-md-3">
        <div class="list-group shadow-sm border-0 mb-4">
            <a asp-action="Profile" class="list-group-item list-group-item-action active bg-primary border-0">
                <i class="bi bi-person-fill"></i> Hồ sơ cá nhân
            </a>
            <a asp-action="MyDocuments" class="list-group-item list-group-item-action">
                <i class="bi bi-file-earmark-arrow-up"></i> Tài liệu đã đăng
            </a>
            <a asp-action="SavedDocuments" class="list-group-item list-group-item-action">
                <i class="bi bi-bookmark-star"></i> Tài liệu đã lưu
            </a>
            <a asp-action="MyQuestions" class="list-group-item list-group-item-action">
                <i class="bi bi-chat-left-dots"></i> Câu hỏi của bạn
            </a>
        </div>
        
        <div class="card border-0 shadow-sm p-3 text-center">
            <h6>Hỗ trợ sinh viên</h6>
            <p class="small text-muted">Nếu có lỗi khi tải file, hãy liên hệ Admin.</p>
            <button class="btn btn-sm btn-outline-dark">Liên hệ hỗ trợ</button>
        </div>
    </div>

    <div class="col-md-9">
        @* Nội dung chi tiết của từng Action sẽ đổ vào đây *@
    </div>
</div>