@model StudyShare.Models.AppUser
@{ 
    ViewData["Title"] = "Trang cá nhân"; 
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_UserSidebarPartial", Model)
        </div>

        <div class="col-md-9">
            
            <div class="card border-0 shadow-sm p-4 rounded-4 bg-gradient bg-primary text-white mb-4">
                <h3 class="fw-bold">Chào bạn, @Model.FullName! 👋</h3>
                <p class="mb-0 opacity-75">Chúc bạn một ngày học tập thật hiệu quả.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center rounded-4 h-100">
                        <h2 class="fw-bold text-primary mb-1">@ViewBag.TotalDocs</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Tài liệu đã đăng</small>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center rounded-4 h-100">
                        <h2 class="fw-bold text-danger mb-1">@ViewBag.TotalSaved</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Tài liệu đã lưu</small>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center rounded-4 h-100">
                        <h2 class="fw-bold text-success mb-1">@ViewBag.TotalQuestions</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Câu hỏi thảo luận</small>
                    </div>
                </div>
            </div> @* Kết thúc hàng thẻ *@

        </div> @* Kết thúc col-md-9 *@
    </div> @* Kết thúc row chính *@
</div> @* Kết thúc container *@