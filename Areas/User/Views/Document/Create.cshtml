@model StudyShare.DTOs.Requests.DocumentCreateRequest
@{
    ViewData["Title"] = "Tải lên tài liệu mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-cloud-arrow-up-fill me-2"></i> Chia sẻ tài liệu</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề tài liệu <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control form-control-lg rounded-3" placeholder="Nhập tiêu đề rõ ràng, ngắn gọn..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Chuyên mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select form-select-lg rounded-3" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn chuyên mục phù hợp --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Giới thiệu sơ lược về nội dung tài liệu này để người khác dễ hình dung..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-4 bg-light border border-2 border-dashed rounded-3 text-center">
                            <label asp-for="File" class="form-label fw-bold d-block mb-3">Chọn tệp tin đính kèm <span class="text-danger">*</span></label>
                            <input asp-for="File" type="file" id="fileInput" class="form-control" accept=".pdf,.docx,.pptx,.xlsx,.txt,.zip,.rar,.png,.jpg" />
                            <span asp-validation-for="File" class="text-danger small d-block mt-2"></span>
                            <div class="form-text mt-2 text-muted">
                                <i class="bi bi-info-circle me-1"></i> Hỗ trợ PDF, Word, Excel, PowerPoint, ZIP, Ảnh (Tối đa 20MB).
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold flex-grow-1 shadow-sm">
                                <i class="bi bi-upload me-2"></i> Tải lên
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 border">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('fileInput').addEventListener('change', function () {
            if (this.files[0] && this.files[0].size > 20 * 1024 * 1024) {
                alert('Tệp tin quá lớn! Vui lòng chọn tệp dưới 20MB.');
                this.value = ''; 
            }
        });
    </script>
}