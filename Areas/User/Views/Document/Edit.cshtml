@model StudyShare.DTOs.Requests.DocumentUpdateRequest
@{
    ViewData["Title"] = "Chỉnh sửa tài liệu";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại tài liệu của tôi
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2 text-warning"></i> Cập nhật tài liệu</h5>
                </div>
                <div class="card-body p-4 p-md-5 bg-light">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-white p-4 rounded-4 shadow-sm border">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold text-dark">Tiêu đề tài liệu <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control form-control-lg rounded-3 bg-light border-0 shadow-sm" />
                            <span asp-validation-for="Title" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-bold text-dark">Chuyên mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select form-select-lg rounded-3 bg-light border-0 shadow-sm" asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-dark">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control rounded-3 bg-light border-0 shadow-sm" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4 p-4 bg-light rounded-4 border">
                            <label class="form-label fw-bold text-dark">Tệp đính kèm hiện tại:</label>
                            <div class="text-primary fw-bold mb-4 fs-5 bg-white p-3 rounded-3 shadow-sm d-inline-block">
                                <i class="bi bi-file-earmark-text me-2"></i> @ViewBag.CurrentFileName
                            </div>
                            
                            <label asp-for="File" class="form-label fw-bold text-dark d-block">Thay thế tệp tin khác (không bắt buộc)</label>
                            <input asp-for="File" type="file" id="fileInput" class="form-control rounded-pill shadow-sm" />
                            <div class="form-text mt-2 text-muted fst-italic"><i class="bi bi-info-circle me-1"></i> Để trống nếu bạn muốn giữ nguyên tệp cũ.</div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-3 border-top mt-4">
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">Hủy</a>
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow-sm text-dark">
                                <i class="bi bi-save me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}