@model StudyShare.DTOs.Requests.DocumentUpdateRequest
@{
    ViewData["Title"] = "Chỉnh sửa tài liệu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-dark text-white py-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Cập nhật tài liệu</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề tài liệu <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control form-control-lg rounded-3" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Chuyên mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select form-select-lg rounded-3" asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded-3 border">
                            <label class="form-label fw-bold">Tệp đính kèm hiện tại:</label>
                            <div class="text-primary fw-semibold mb-3">
                                <i class="bi bi-file-earmark-text me-1"></i> @ViewBag.CurrentFileName
                            </div>
                            
                            <label asp-for="File" class="form-label fw-bold">Thay thế tệp tin khác (không bắt buộc)</label>
                            <input asp-for="File" type="file" id="fileInput" class="form-control" />
                            <div class="form-text mt-2 text-muted">Để trống nếu bạn muốn giữ nguyên tệp cũ.</div>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold flex-grow-1 shadow-sm">
                                Lưu thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 border">
                                Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}