@model IEnumerable<StudyShare.Models.Document>
@{ ViewData["Title"] = "Tài liệu của tôi"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Tài liệu cá nhân</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill">Tải lên bản mới</a>
    </div>

    <div class="table-responsive bg-white shadow-sm rounded-4 p-3">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Ngày đăng</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.UploadDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if(item.IsApproved) { 
                            <span class="badge bg-success">Đã duyệt</span> 
                        } else { 
                            <span class="badge bg-warning text-dark">Chờ duyệt</span> 
                        }
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>