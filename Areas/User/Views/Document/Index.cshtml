@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{ ViewData["Title"] = "Tài liệu của tôi"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Tài liệu cá nhân</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill">Tải lên bản mới</a>
    </div>

    <div class="table-responsive bg-white shadow-sm rounded-4 p-3">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Ngày đăng</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th> @* Thêm tiêu đề cột *@
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.CategoryName</td>
                    <td>@item.UploadDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if(item.IsApproved) { 
                            <span class="badge bg-success">Đã duyệt</span> 
                        } else { 
                            <span class="badge bg-warning text-dark">Chờ duyệt</span> 
                        }
                    </td>
                    <td class="text-center">
                        @* Nút Sửa mới thêm vào *@
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1" title="Sửa tài liệu">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>