@model StudyShare.ViewModels.DocumentViewModel
@{
    ViewData["Title"] = "Chi tiết tài liệu";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại tài liệu của tôi
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start">
                        <div class="mb-3 mb-md-0">
                            <span class="badge bg-primary mb-2 px-3 py-2 rounded-pill shadow-sm">@Model.CategoryName</span>
                            <h3 class="fw-bold mb-2 text-dark">@Model.Title</h3>
                            <p class="text-muted mb-0">
                                <i class="bi bi-person-circle me-1"></i> Đăng bởi: <strong class="text-dark">@Model.AuthorName</strong> 
                                <span class="mx-2 text-secondary">|</span> 
                                <i class="bi bi-calendar3 me-1"></i> @Model.UploadDate.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        </div>
                        <div>
                            @if (Model.IsApproved)
                            {
                                <span class="badge bg-success-subtle text-success border border-success px-3 py-2 fs-6 rounded-pill shadow-sm">
                                    <i class="bi bi-check-circle-fill me-1"></i> Đã duyệt
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning px-3 py-2 fs-6 rounded-pill shadow-sm">
                                    <i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt
                                </span>
                            }
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold border-bottom pb-2 mb-4 text-dark"><i class="bi bi-card-text text-primary me-2"></i>Mô tả tài liệu</h5>
                    <div class="mb-5 text-secondary" style="line-height: 1.7; white-space: pre-wrap; font-size: 1.05rem;">@(string.IsNullOrWhiteSpace(Model.Description) ? "Tài liệu này không có mô tả chi tiết." : Model.Description)</div>

                    <h5 class="fw-bold border-bottom pb-2 mb-4 text-dark"><i class="bi bi-paperclip text-primary me-2"></i>Tệp đính kèm</h5>
                    <div class="d-flex flex-column flex-md-row align-items-center bg-light p-4 rounded-4 border shadow-sm">
                        <div class="display-3 me-md-4 mb-3 mb-md-0">
                            @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-pdf-fill text-danger"></i> }
                            else if (Model.FileName.EndsWith(".doc", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".docx", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-word-fill text-primary"></i> }
                            else if (Model.FileName.EndsWith(".zip", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".rar", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-zip-fill text-warning"></i> }
                            else if (Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-image-fill text-success"></i> }
                            else { <i class="bi bi-file-earmark-text-fill text-secondary"></i> }
                        </div>
                        
                        <div class="flex-grow-1 text-center text-md-start mb-3 mb-md-0">
                            <h5 class="fw-bold mb-1 text-break text-dark">@Model.FileName</h5>
                            <span class="badge bg-secondary mb-1">@Model.FileType</span>
                            <small class="text-muted d-block mt-1">Kích thước: @(Model.FileSize / 1024) KB</small>
                        </div>
                        
                        <div class="ms-md-3 d-flex flex-wrap gap-2 justify-content-center">
                            @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) || 
                                 Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
                                 Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
                                 Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
                            {
                                <button type="button" class="btn btn-outline-info btn-lg rounded-pill shadow-sm px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#previewModal">
                                    <i class="bi bi-eye me-2"></i> Xem trước
                                </button>
                            }

                            <a asp-area="User" asp-controller="Document" asp-action="Download" asp-route-id="@Model.Id" 
                               class="btn btn-success btn-lg rounded-pill shadow-sm px-4 fw-bold">
                                <i class="bi bi-download me-2"></i> Tải xuống
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="card-footer bg-light p-4 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold">
                        <i class="bi bi-pencil me-1"></i> Chỉnh sửa
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài liệu này không? Hành động này không thể hoàn tác.')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger px-4 rounded-pill shadow-sm fw-bold">
                            <i class="bi bi-trash me-1"></i> Xóa tài liệu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
{
    <div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header bg-dark text-white border-0 p-3">
                    <h5 class="modal-title fw-bold m-0" id="previewModalLabel">
                        <i class="bi bi-eye me-2 text-info"></i>Xem trước: @Model.FileName
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 bg-secondary" style="height: 80vh;">
                    @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe src="~/@Model.FilePath" style="width: 100%; height: 100%; border: none;"></iframe>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center h-100 p-3">
                            <img src="~/@Model.FilePath" class="img-fluid shadow-lg rounded-3" style="max-height: 75vh; object-fit: contain;" alt="Preview" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}