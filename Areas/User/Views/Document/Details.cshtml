@model StudyShare.ViewModels.DocumentViewModel
@{
    ViewData["Title"] = "Chi tiết tài liệu";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-primary mb-2 px-3 py-2 rounded-pill shadow-sm">@Model.CategoryName</span>
                    <h2 class="fw-bold mb-2 text-dark">@Model.Title</h2>
                    <p class="text-muted mb-0 fs-6">
                        <i class="bi bi-person-circle me-1"></i> Đăng bởi: <strong>@Model.AuthorName</strong> 
                        &nbsp;|&nbsp; 
                        <i class="bi bi-calendar3 me-1"></i> @Model.UploadDate.ToString("dd/MM/yyyy HH:mm")
                    </p>
                </div>
                <div>
                    @if (Model.IsApproved)
                    {
                        <span class="badge bg-success-subtle text-success border border-success px-3 py-2 fs-6 rounded-3">
                            <i class="bi bi-check-circle-fill me-1"></i> Đã duyệt
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning px-3 py-2 fs-6 rounded-3">
                            <i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt
                        </span>
                    }
                </div>
            </div>
        </div>
        
        <div class="card-body p-4 p-md-5">
            <h5 class="fw-bold border-bottom pb-2 mb-4 text-dark"><i class="bi bi-card-text me-2"></i>Mô tả tài liệu</h5>
            <div class="mb-5 text-secondary fs-5" style="line-height: 1.7; white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Description) ? "Tài liệu này không có mô tả chi tiết." : Model.Description)</div>

            <h5 class="fw-bold border-bottom pb-2 mb-4 text-dark"><i class="bi bi-paperclip me-2"></i>Tệp đính kèm</h5>
            <div class="d-flex flex-column flex-md-row align-items-center bg-light p-4 rounded-4 border">
                <div class="display-3 text-danger me-md-4 mb-3 mb-md-0">
                    @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-pdf-fill"></i> }
                    else if (Model.FileName.EndsWith(".doc", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".docx", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-word-fill text-primary"></i> }
                    else if (Model.FileName.EndsWith(".zip", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".rar", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-zip-fill text-warning"></i> }
                    else if (Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-earmark-image-fill text-success"></i> }
                    else { <i class="bi bi-file-earmark-text-fill text-secondary"></i> }
                </div>
                <div class="flex-grow-1 text-center text-md-start mb-3 mb-md-0">
                    <h5 class="fw-bold mb-1 text-break">@Model.FileName</h5>
                    <span class="badge bg-secondary mb-1">@Model.FileType</span>
                    <small class="text-muted d-block mt-1">Kích thước: @(Model.FileSize / 1024) KB</small>
                </div>
                
                <div class="ms-md-3 d-flex flex-wrap gap-2 justify-content-center">
                    
                    @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) || 
                         Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
                         Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
                         Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="btn btn-outline-info btn-lg rounded-pill shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#previewModal">
                            <i class="bi bi-eye me-2"></i> Xem trước
                        </button>
                    }

                    <a asp-area="User" asp-controller="Document" asp-action="Download" asp-route-id="@Model.Id" 
                    class="btn btn-success btn-lg rounded-pill shadow-sm px-4">
                        <i class="bi bi-download me-2"></i> Tải xuống (10 điểm)
                    </a>
                </div>
            </div>
        </div>
        
        <div class="card-footer bg-light p-4 border-top d-flex justify-content-end gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 rounded-pill">
                <i class="bi bi-pencil me-1"></i> Chỉnh sửa
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài liệu này không? Hành động này không thể hoàn tác.')">
                <button type="submit" class="btn btn-outline-danger px-4 rounded-pill">
                    <i class="bi bi-trash me-1"></i> Xóa tài liệu
                </button>
            </form>
        </div>
    </div>
</div>

@if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
     Model.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
{
    <div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold" id="previewModalLabel">
                        <i class="bi bi-eye me-2 text-info"></i>Xem trước: @Model.FileName
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 bg-dark" style="height: 80vh;">
                    @if (Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe src="~/@Model.FilePath" style="width: 100%; height: 100%; border: none;"></iframe>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center h-100 bg-secondary">
                            <img src="~/@Model.FilePath" class="img-fluid shadow" style="max-height: 80vh; object-fit: contain;" alt="Preview" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}