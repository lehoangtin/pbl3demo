<h2>@Model.Title</h2>

<a href="@Model.FilePath" class="btn btn-primary" target="_blank">
    Mở file
</a>
<a asp-area="User" asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success">
    Download
</a>
<hr />

@if (Model.FileType == ".pdf")
{
    <iframe src="@Model.FilePath" width="100%" height="600px"></iframe>
}
else
{
    <iframe 
        src="https://view.officeapps.live.com/op/embed.aspx?src=@(Context.Request.Scheme + "://" + Context.Request.Host + Model.FilePath)"
        width="100%" height="600px">
    </iframe>
}