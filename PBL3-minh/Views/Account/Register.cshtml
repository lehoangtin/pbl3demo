@model StudyShare.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Tham gia StudyShare"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5">
                <h2 class="text-center mb-4 fw-bold text-primary">Tạo tài khoản</h2>
                
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input asp-for="FullName" class="form-control rounded-pill" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input asp-for="Email" class="form-control rounded-pill" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <input asp-for="Password" class="form-control rounded-pill" type="password" placeholder="Tối thiểu 8 ký tự, có chữ hoa, số..." />
                        
                        <div class="form-text small text-muted mt-1" style="font-size: 0.8rem; padding-left: 10px;">
                            <i class="bi bi-info-circle"></i> Mật khẩu cần tối thiểu 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt.
                        </div>
                        
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-pill" type="password" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 fw-bold rounded-pill shadow-sm">
                        Đăng ký ngay
                    </button>
                </form>

                <p class="text-center mt-4">
                    Đã có tài khoản? <a asp-action="Login" class="text-decoration-none">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>