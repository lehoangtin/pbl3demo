@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                </div>
                
                <h3 class="fw-bold mb-3 text-success">Thành công!</h3>
                
                <p class="text-muted mb-4">
                    Mật khẩu của bạn đã được đặt lại thành công. Bây giờ bạn có thể sử dụng mật khẩu mới để tiếp tục khám phá StudyShare.
                </p>
                
                <a asp-action="Login" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm">
                    Quay lại Đăng nhập ngay
                </a>
            </div>
        </div>
    </div>
</div>