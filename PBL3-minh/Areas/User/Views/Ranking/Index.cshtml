@using StudyShare.Models
@model IEnumerable<StudyShare.Models.AppUser>

@{
    ViewData["Title"] = "Bảng Vàng Thành Tích";
    int rank = 1; // Khởi tạo biến đếm thứ hạng
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 text-center">
        <h2 class="display-5 fw-bold text-warning mb-3"><i class="bi bi-trophy-fill"></i> Bảng Vàng Thành Tích</h2>
        <p class="text-muted fs-5">Vinh danh những thành viên đóng góp tích cực nhất cho Hệ sinh thái Học tập.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0" style="border-radius: 15px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted">
                            <tr>
                                <th class="text-center" style="width: 15%">Hạng</th>
                                <th style="width: 50%">Thành viên</th>
                                <th class="text-center" style="width: 35%">Điểm tích lũy</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr class="@(rank <= 3 ? "fw-bold" : "")">
                                    <td class="text-center fs-4">
                                        @if (rank == 1)
                                        {
                                            <i class="bi bi-award-fill text-warning" title="Huy chương Vàng"></i>
                                        }
                                        else if (rank == 2)
                                        {
                                            <i class="bi bi-award-fill text-secondary" title="Huy chương Bạc"></i>
                                        }
                                        else if (rank == 3)
                                        {
                                            <i class="bi bi-award-fill" style="color: #cd7f32;" title="Huy chương Đồng"></i>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-5">#@rank</span>
                                        }
                                    </td>
                                    
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=@user.UserName&background=random" class="rounded-circle me-3 shadow-sm" width="45" alt="Avatar">
                                            <div>
                                                <h5 class="mb-0 text-primary">@user.UserName</h5>
                                            </div>
                                        </div>
                                    </td>
                                    
                                    <td class="text-center">
                                        <span class="badge rounded-pill @(rank <= 3 ? "bg-success" : "bg-secondary") fs-6 px-3 py-2">
                                            <i class="bi bi-coin"></i> @user.Points Điểm
                                        </span>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>