@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@inject SignInManager<StudyShare.Models.AppUser> SignInManager
@model IEnumerable<StudyShare.Models.Question>

@{ 
    ViewData["Title"] = "Cộng đồng thảo luận"; 
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Cộng đồng Thảo luận</h2>
        
        @* Nút hành động chính dựa trên trạng thái đăng nhập *@
        @if (SignInManager.IsSignedIn(User))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg"></i> Đặt câu hỏi
            </a>
        }
        else
        {
            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-outline-primary rounded-pill px-4">
                Đăng nhập để đặt câu hỏi
            </a>
        }
    </div>

    @* Cấu trúc bảng giống hệt View Document *@
    <div class="table-responsive bg-white shadow-sm rounded-4 p-3">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 40%;">Nội dung câu hỏi</th>
                    <th>Người đăng</th>
                    <th>Ngày tạo</th>
                    <th class="text-center">Phản hồi</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var q in Model) {
                <tr>
                    <td class="fw-bold">
                        <a asp-action="Details" asp-route-id="@q.Id" class="text-decoration-none text-dark">
                            @* Cắt ngắn nội dung nếu quá dài *@
                            @(q.Content.Length > 80 ? q.Content.Substring(0, 80) + "..." : q.Content)
                        </a>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="@(q.User?.Avatar ?? "/images/default-avatar.png")" 
                                 class="rounded-circle me-2" width="30" height="30" style="object-fit: cover;">
                            <span class="small">@(q.User?.FullName ?? "Ẩn danh")</span>
                        </div>
                    </td>
                    <td>@q.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <span class="badge bg-light text-dark border">
                            @q.Answers.Count <i class="bi bi-chat-dots ms-1"></i>
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group">
                            @* Nút Xem chi tiết luôn hiển thị *@
                            <a asp-action="Details" asp-route-id="@q.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>

                            @* Chỉ hiện nút Sửa nếu là chủ sở hữu bài đăng *@
                            @if (q.UserId == currentUserId) {
                                <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-sm btn-outline-warning ms-1" title="Sửa bài">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            }
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            // Xử lý thông báo lỗi (Ví dụ: Thao tác Report không hợp lệ chuyển hướng về Index)
            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi thao tác!',
                    text: '@Html.Raw(TempData["Error"])',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Đóng'
                });
                </text>
            }

            // Xử lý thông báo thành công chung (nếu có)
            @if (TempData["Message"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Message"])',
                    confirmButtonColor: '#3085d6',
                    confirmButtonText: 'Đóng'
                });
                </text>
            }
        });
    </script>
}