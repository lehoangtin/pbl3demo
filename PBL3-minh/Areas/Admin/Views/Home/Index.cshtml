@model IEnumerable<StudyShare.Models.Document>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card p-3 bg-primary text-white shadow-sm">
                <h6>Người dùng</h6>
                <h2>@ViewBag.UserCount</h2>
            </div>
        </div>
        </div>

    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h5 class="fw-bold mb-3">Tài liệu mới chờ duyệt</h5>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Tên tài liệu</th>
                        <th>Người đăng</th>
                        <th>Ngày</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @* Kiểm tra Model để tránh lỗi sập trang *@
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.User?.FullName</td>
                                <td>@item.UploadDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <form asp-area="Admin" asp-controller="Document" asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Duyệt ngay</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Không có tài liệu nào đang chờ duyệt.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>