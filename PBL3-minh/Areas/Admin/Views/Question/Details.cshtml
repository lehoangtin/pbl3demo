@model StudyShare.Models.Question

<div class="container mt-4">
    <div class="card border-primary mb-4 shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Câu hỏi từ: <strong>@Model.User?.FullName</strong></span>
            <small>ID: @Model.Id</small>
        </div>
        <div class="card-body">
            <h4 class="card-title fw-bold">@Model.Content</h4>
            <p class="card-text text-muted">Đăng lúc: @Model.CreatedAt.ToString("HH:mm dd/MM/yyyy")</p>
        </div>
    </div>

    <h4>💬 Các câu trả lời (@(Model.Answers?.Count ?? 0))</h4>
    <hr />
<form asp-area="User" asp-controller="Question" asp-action="Report" method="post" class="d-inline">
    <input type="hidden" name="questionId" value="@Model.Id" />
    <select name="reason" class="form-select form-select-sm d-inline-block w-auto" required>
        <option value="">-- Lý do báo cáo --</option>
        <option value="Spam">Nội dung rác (Spam)</option>
        <option value="Toxic">Ngôn từ độc hại</option>
        <option value="WrongContent">Sai nội dung học tập</option>
    </select>
    <button type="submit" class="btn btn-sm btn-outline-danger">Báo cáo</button>
</form>
    @if (Model.Answers != null && Model.Answers.Any())
    {
        @* 🔥 Sử dụng kiểm tra null trước khi sắp xếp *@
        @foreach (var ans in Model.Answers.OrderByDescending(x => x.CreatedAt))
        {
            <div class="card mb-3 border-0 shadow-sm bg-light">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <span class="fw-bold text-primary">@ans.User?.FullName:</span> @ans.Content
                        <br />
                        <small class="text-muted">@ans.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <form asp-area="Admin" asp-controller="Question" asp-action="DeleteAnswer" method="post">
                        <input type="hidden" name="id" value="@ans.Id" />
                        <input type="hidden" name="questionId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" onclick="return confirm('Xóa câu trả lời này?')">Xóa bài</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-secondary">Chưa có câu trả lời nào cho câu hỏi này.</div>
    }
</div>