@model IEnumerable<StudyShare.ViewModels.ReportedUserViewModel>

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Người dùng</th>
            <th class="text-center">Số lần báo cáo</th> @* Thay đổi tiêu đề *@
            <th class="text-center">Số người báo cáo</th>
            <th>Trạng thái</th>
            <th class="text-end">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    <strong>@item.FullName</strong><br/>
                    <small class="text-muted">@item.Email</small>
                </td>
                <td class="text-center">
                    <span class="badge bg-info">@item.TotalReports lần</span>
                </td>
                <td class="text-center">
                    <span class="badge @(item.UniqueReporters >= 3 ? "bg-danger" : "bg-warning")">
                        @item.UniqueReporters người
                    </span>
                </td>
                <td>
                    @if(item.IsBanned) { <span class="text-danger">Đã khóa</span> }
                    else { <span class="text-success">Hoạt động</span> }
                </td>
                <td class="text-end">
                    @* 🔥 NÚT MỚI: Xem chi tiết các lời báo cáo *@
                    <a asp-action="ViewReports" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary">
                        Chi tiết báo cáo
                    </a>
                    
                    <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-info text-white">Hồ sơ</a>
                    
                    <form asp-action="ToggleBan" asp-route-id="@item.UserId" method="post" class="d-inline">
                        <button class="btn btn-sm @(item.IsBanned ? "btn-success" : "btn-danger")">
                            @(item.IsBanned ? "Mở khóa" : "Khóa ngay")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>